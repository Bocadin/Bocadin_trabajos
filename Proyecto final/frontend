        archivo = filedialog.askopenfilename(filetypes=[("Imágenes", "*.png *.jpg *.jpeg")])
        ventana_rep_u.attributes("-topmost", True)
        
        adjuntando = False
        if archivo:
            base_dir = os.path.dirname(os.path.abspath(__file__))
            carpeta_reps = os.path.join(base_dir, "evidencias_reportes")
            os.makedirs(carpeta_reps, exist_ok=True)
            
            nombre_archivo = f"rep_{usuario_obj.idUsuario}_{idx}_{datetime.now().strftime('%Y%m%d%H%M%S')}_{os.path.basename(archivo)}"
            destino = os.path.join(carpeta_reps, nombre_archivo)
            shutil.copy(archivo, destino)
            fotos_paths[idx] = destino
            
            # Actualizar botón con miniatura o éxito
            btns_ev[idx].configure(text="✅ Cargada", fg_color="#10B981")

    btns_ev = []
    for i in range(3):
