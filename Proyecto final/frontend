def cargar_icono(nombre_archivo):
    try:
        carpeta_iconos = os.path.join(os.path.dirname(__file__), "iconos")
        ruta = os.path.join(carpeta_iconos, nombre_archivo)
        img = Image.open(ruta)
        return ctk.CTkImage(img, size=(30, 30))
    except FileNotFoundError:
        print(f"Error: El archivo '{nombre_archivo}' no se encontró en la carpeta ")
        return None

icono_usuario  = cargar_icono("icono_usuario.png")
icono_admin    = cargar_icono("icono_admin.png")
icono_registro = cargar_icono("icono_registro.png")

