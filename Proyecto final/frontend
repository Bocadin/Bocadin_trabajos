        if usuario_creado:
            mostrar_exito()
            ventana_reg.destroy()
            ventana_menu.deiconify()
        else:
            print("El usuario ya existe.")

    ctk.CTkButton(ventana_reg, 
                  text="Acceso", 
                  fg_color=Color_boton_oscuro, 
                  command=ejecutar_registro
                  ).pack(pady=30)

