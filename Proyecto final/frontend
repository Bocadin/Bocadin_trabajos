        ctk.CTkLabel(footer, text="ℹ️ Este es un cálculo estimado. El total puede variar al generar el recibo.", 
                     font=("Inter", 12), text_color="#166534").pack(pady=10)

    btn_vp = ctk.CTkButton(actions, text="👁️ Vista Previa", fg_color=Color_boton_oscuro, text_color="white", 
                            border_color=Color_boton_oscuro, border_width=1, height=45, corner_radius=10, command=mostrar_vista_previa)
    btn_vp.pack(side="left", fill="x", expand=True, padx=(0, 5))

    def guardar():
        pendientes = obtener_pendientes()
        total = sum(c.total(sistema_back) for c in pendientes)
        if total <= 0:
            mostrar_error("No hay consumos pendientes.")
            return
        
        c_ids = [c.idConsumo for c in pendientes]
        res_val = combo_residente.get()
        res_id = res_val.split(" - ")[0] if tipo_var.get() == "individual" else "varios"
        
        # Generar recibo en backend con todos los parámetros necesarios
        r = sistema_back.generar_recibo(res_id, ent_periodo.get(), total, c_ids)
        if r:
            mostrar_exito("Recibo generado con éxito.")
            ventana_recibo.destroy()
        else:
            mostrar_error("No se pudo generar el recibo.")

    btn_save = ctk.CTkButton(actions, text="💾 Guardar", fg_color=Color_boton_oscuro, text_color="white", border_color=Color_boton_oscuro,
                              height=45, corner_radius=10, command=guardar)
    btn_save.pack(side="left", fill="x", expand=True, padx=(5, 0))

    btn_print = ctk.CTkButton(content, text="🖨️ Imprimir", fg_color=Color_boton_oscuro, text_color="white", 
                               border_color=Color_boton_oscuro, border_width=1, height=45, corner_radius=10, command=lambda: print("Imprimiendo..."))
    btn_print.pack(fill="x", pady=(15, 0))


