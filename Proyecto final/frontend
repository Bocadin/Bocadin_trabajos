def cargar_icono(nombre_archivo):
    try:
        if os.path.isabs(nombre_archivo):
            ruta = nombre_archivo
        else:
            carpeta_iconos = os.path.join(os.path.dirname(__file__), "iconos")
            ruta = os.path.join(carpeta_iconos, nombre_archivo)
        
        if not os.path.exists(ruta):
            return None
            
        img = Image.open(ruta)
        return ctk.CTkImage(img, size=(30, 30))
    except Exception as e:
        print(f"Error al cargar icono '{nombre_archivo}': {e}")
        return None

