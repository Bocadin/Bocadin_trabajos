    #Crea la ventana secundaria para gestionar los servicios 
    ventana_servicios = ctk.CTkToplevel(ventana_principal)
    ventana_servicios.title("Gestión de Servicios")
    ventana_servicios.geometry("850x550")
    ventana_servicios.configure(fg_color="white")
