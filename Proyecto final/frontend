        desc = txt_desc.get("1.0", "end-1c").strip()
        cat = combo_cat.get()
        nom_rep = ent_nombre_rep.get().strip()
        
        if not asunto or not desc or not nom_rep:
            mostrar_error("Por favor completa todos los campos.")
            return
        
        sistema_back.crear_reporte(
            usuario_id=usuario_obj.idUsuario,
            titulo=asunto,
            tipo=cat,
            descripcion=desc,
            prioridad="Media",
            foto1=fotos_paths[0],
            foto2=fotos_paths[1],
            foto3=fotos_paths[2],
            nombre_reporta=nom_rep
        )
        mostrar_exito()
        ventana_rep_u.destroy()

    btn_enviar = ctk.CTkButton(footer, text="🚀 Enviar Reporte", fg_color=Color_boton_oscuro, text_color="white", 
