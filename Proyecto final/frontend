def abrir_ventana_pagos(usuario_obj, ventana_padre):
    ventana_padre.withdraw()
    ventana_pagos = ctk.CTkToplevel()
    ventana_pagos.title("Centro de Pagos - Simulación")
    ventana_pagos.geometry("1000x700")
    ventana_pagos.configure(fg_color=Color_fondo) 
    ventana_pagos.attributes("-topmost", True)

    
    # Header Frame 
    header_frame = ctk.CTkFrame(ventana_pagos, fg_color="#BCDFC2", height=80, corner_radius=0)
    header_frame.pack(fill="x", side="top")
    header_frame.pack_propagate(False)
    
    ctk.CTkButton(header_frame, text="← Regresar", fg_color="#8B0000", width=120, command=lambda: [ventana_pagos.destroy(), ventana_padre.deiconify()]).pack(side="right", padx=20)

    # Info de pago en el header
    pago_info = usuario_obj.obtener_informacion_pago(sistema_back)
    # Simulación de días para el diseño
    dias_vence = "5 DÍAS" if "pendiente" in pago_info["monto"].lower() or pago_info["monto"] != "$0.00" else "0 DÍAS"
    fecha_vence = datetime.now().strftime("%d %b %Y").upper()

    header_content = ctk.CTkFrame(header_frame, fg_color="transparent")
    header_content.pack(expand=True)

    global _img_pago_ref # Referencia global para evitar recolección de basura
    _img_pago_ref = None

    # Label del logo
    lbl_logo_header = ctk.CTkLabel(header_content, text="🏢", font=("Arial", 30))
    lbl_logo_header.pack(side="left", padx=10)

    #Funcion cargar iconos
    try:
        base_dir = os.path.dirname(os.path.abspath(__file__))
        ruta_logo = os.path.join(base_dir, "iconos", "icono_pagos.png")

        if os.path.exists(ruta_logo):
            img_edif = Image.open(ruta_logo)
            _img_pago_ref = ctk.CTkImage(img_edif, size=(50, 50))
            lbl_logo_header.configure(image=_img_pago_ref, text="")

    except Exception as e:
        print(f"Error cargando icono del header: {e}")

    lbl_info_pago = ctk.CTkLabel(header_content, 
                                 text=f"SIGUIENTE PAGO: {pago_info['monto']} | VENCE EN {dias_vence} ({fecha_vence})",
                                 font=("Inter", 16, "bold"), text_color=Color_texto_oscuro)
    lbl_info_pago.pack(side="left", padx=20)

    def realizar_pago_click():
        if not metodo_seleccionado.get():
            mostrar_error("Seleccione una forma de pago")
            return
            
        serv_ids = [cid for cid, var in servicios_vars.items() if var.get()]
        if not serv_ids:
            mostrar_error("No ha seleccionado ningún servicio para pagar")
            return
            
        # Procesar pago de los servicios seleccionados
        for cid in serv_ids:
            sistema_back.marcar_consumo_pagado(cid)
            
        # Verificar si los recibos ahora están totalmente pagados
        # (Si todos los consumos de un recibo están pagados, el recibo se marca como pagado)
        for r in sistema_back.recibos.values():
            if r.estado == "pendiente":
                if all(c.estado == "pagado" for c in r.consumos):
                    r.estado = "pagado"
        
        sistema_back.guardar_recibos_csv()
        sistema_back.guardar_consumos_csv()
        
        mostrar_exito(f"Se han pagado {len(serv_ids)} servicio(s) correctamente")
        ventana_pagos.destroy()
        abrir_ventana_pagos(usuario_obj, ventana_padre)

    btn_pago_ahora = ctk.CTkButton(header_content, text="💸 REALIZAR PAGO", 
                                   fg_color="#E5E7EB", text_color=Color_texto_oscuro,
                                   font=("Inter", 14, "bold"), height=40,
                                   hover_color="#D1D5DB", command=realizar_pago_click)
    btn_pago_ahora.pack(side="left", padx=10)

    # Main Scrollable Area
    main_scroll = ctk.CTkScrollableFrame(ventana_pagos, fg_color="transparent")
    main_scroll.pack(fill="both", expand=True, padx=20, pady=20)

    # Mid section split in two
    mid_frame = ctk.CTkFrame(main_scroll, fg_color="transparent")
    mid_frame.pack(fill="x", pady=(0, 20))
    mid_frame.grid_columnconfigure(0, weight=1)
    mid_frame.grid_columnconfigure(1, weight=1)

    #Frame info
    resumen_frame = ctk.CTkFrame(mid_frame, fg_color="white", corner_radius=15, border_width=1, border_color="#D1D5DB")
    resumen_frame.grid(row=0, column=0, sticky="nsew", padx=(0, 10))

    ctk.CTkLabel(resumen_frame, text="RESUMEN DETALLADO", font=("Inter", 18, "bold"), text_color="#111827").pack(anchor="w", padx=20, pady=(20, 5))
    
    # Selección individual de servicios
    servicios_scroll = ctk.CTkScrollableFrame(resumen_frame, fg_color="#F8FAFC", height=300, corner_radius=10, border_width=1, border_color="#E2E8F0")
    servicios_scroll.pack(fill="both", expand=True, padx=20, pady=10)
    
    servicios_vars = {} # {id_consumo: ctk.BooleanVar}
    
    def on_service_toggle():
        actualizar_total_pago()

    def actualizar_total_pago():
        total = 0
        for c_id, var in servicios_vars.items():
            if var.get():
                c_obj = sistema_back.consumos.get(c_id)
                if c_obj: total += c_obj.total(sistema_back)
        lbl_info_pago.configure(text=f"MONTO SELECCIONADO: ${total:.2f} | VENCE EN {dias_vence} ({fecha_vence})")

    mis_recs = [r for r in sistema_back.recibos.values() if str(getattr(r.usuario, 'idUsuario', r.usuario)) == str(usuario_obj.idUsuario)]
    pendientes = [r for r in mis_recs if r.estado == "pendiente"]

    if not pendientes:
        ctk.CTkLabel(servicios_scroll, text="No hay servicios pendientes", font=("Inter", 12), text_color="gray").pack(pady=20)
    else:
        for r in pendientes:
            # Header del Recibo 
            r_head = ctk.CTkFrame(servicios_scroll, fg_color="#E2E8F0", corner_radius=5)
            r_head.pack(fill="x", pady=(10, 5), padx=5)
            ctk.CTkLabel(r_head, text=f"RECIBO #{r.idRecibo} - {r.periodo.upper()}", font=("Inter", 11, "bold"), text_color="#475569").pack(padx=10, pady=2)
            
            for c in r.consumos:
                if c.estado != "pendiente": continue
                
                serv_obj = sistema_back.servicios.get(c.servicio_id)
                nom = serv_obj.nombre if serv_obj else "Servicio"
                monto = c.total(sistema_back)
                
                row = ctk.CTkFrame(servicios_scroll, fg_color="white", corner_radius=8, border_width=1, border_color="#F1F5F9")
                row.pack(fill="x", pady=2, padx=5)
                
                var = ctk.BooleanVar(value=False)
                servicios_vars[c.idConsumo] = var
                
                cb = ctk.CTkCheckBox(row, text="", variable=var, width=20, command=on_service_toggle, fg_color="#1E293B")
                cb.pack(side="left", padx=10)
                
                # Icono
                icon_f = f"icono_{nom.lower()}.png"
                img_ctk = cargar_icono(icon_f)
                if img_ctk:
                    ctk.CTkLabel(row, image=img_ctk, text="").pack(side="left", padx=5)
                else:
                    emojis = {"Agua": "💧", "Luz": "💡", "Gas": "🔥", "Seguridad": "🛡️", "Mantenimiento": "🛠️"}
                    ctk.CTkLabel(row, text=emojis.get(nom, "📄"), font=("Arial", 16)).pack(side="left", padx=5)
                
                ctk.CTkLabel(row, text=nom, font=("Inter", 13, "bold"), text_color="#1E293B").pack(side="left", padx=5)
                ctk.CTkLabel(row, text=f"${monto:.2f}", font=("Inter", 13, "bold"), text_color="#111827").pack(side="right", padx=15)

    actualizar_total_pago()

    #Frame métodos de pago
    metodos_frame = ctk.CTkFrame(mid_frame, fg_color="white", corner_radius=15, border_width=1, border_color="#D1D5DB")
    metodos_frame.grid(row=0, column=1, sticky="nsew", padx=(10, 0))

    ctk.CTkLabel(metodos_frame, text="MÉTODOS DE PAGO Y GESTIÓN", font=("Inter", 18, "bold"), text_color="#111827").pack(anchor="w", padx=20, pady=(20, 5))
    ctk.CTkLabel(metodos_frame, text="SELECCIONAR MODO DE PAGO", font=("Inter", 12, "bold"), text_color="gray").pack(anchor="w", padx=20)

    metodo_seleccionado = ctk.StringVar(value="")

    def crear_opcion_pago(parent, icon_char, title, sub, val, color_base):
        f = ctk.CTkFrame(parent, fg_color="white", corner_radius=12, border_width=2, border_color="#E5E7EB", height=80)
        f.pack(fill="x", padx=20, pady=10)
        f.pack_propagate(False)

        rb = ctk.CTkRadioButton(f, text="", variable=metodo_seleccionado, value=val, width=20)
        rb.place(x=15, rely=0.5, anchor="w")

        icon_box = ctk.CTkFrame(f, fg_color=color_base, width=50, height=50, corner_radius=8)
        icon_box.place(x=50, rely=0.5, anchor="w")
        icon_box.pack_propagate(False)
        ctk.CTkLabel(icon_box, text=icon_char, font=("Arial", 24), text_color="white").pack(expand=True)

        txt_f = ctk.CTkFrame(f, fg_color="transparent")
        txt_f.place(x=110, rely=0.5, anchor="w")
        ctk.CTkLabel(txt_f, text=title, font=("Inter", 14, "bold"), text_color="#111827").pack(anchor="w")
        ctk.CTkLabel(txt_f, text=sub, font=("Inter", 11), text_color="gray").pack(anchor="w")

        # Hacer que toda la celda sea clickable
        def on_click(e):
            metodo_seleccionado.set(val)
        
        f.bind("<Button-1>", on_click)
        for child in f.winfo_children():
            child.bind("<Button-1>", on_click)

    crear_opcion_pago(metodos_frame, "💳", "Tarjeta Bancaria (Visa/MC)", "Rápido y Seguro", "tarjeta", "#1A365D")
    crear_opcion_pago(metodos_frame, "🏦", "Transferencia Bancaria", "Detalles de Cuenta", "transfer", "#2D5A27")
    crear_opcion_pago(metodos_frame, "🌐", "Pago en Línea", "Portal Seguro", "online", "#1E3A8A")

    #Botones adicionales
    historial_frame = ctk.CTkFrame(main_scroll, fg_color="white", corner_radius=15, border_width=1, border_color="#D1D5DB")
    historial_frame.pack(fill="both", expand=True, pady=10)

    header_historial = ctk.CTkFrame(historial_frame, fg_color="transparent")
    header_historial.pack(fill="x", padx=20, pady=15)

    ctk.CTkLabel(header_historial, text="HISTORIAL DE CONSUMOS", font=("Inter", 18, "bold"), text_color="#111827").pack(side="left")
    
    # Filtro por servicio
    servicios_unicos = ["Todos"] + [s.nombre for s in sistema_back.servicios.values()]
    combo_filtro_serv = ctk.CTkComboBox(header_historial, values=servicios_unicos, width=180)
    combo_filtro_serv.set("Todos")
    combo_filtro_serv.pack(side="right", padx=10)
    ctk.CTkLabel(header_historial, text="Filtrar por servicio:", font=("Inter", 12), text_color="gray").pack(side="right")

    # Tabla de consumos
    table_container = ctk.CTkFrame(historial_frame, fg_color="transparent")
    table_container.pack(fill="both", expand=True, padx=20, pady=(0, 20))

    # Header de tabla
    table_head = ctk.CTkFrame(table_container, fg_color="#F9FAFB", height=40)
    table_head.pack(fill="x")
    cols = ["FECHA", "SERVICIO", "CANTIDAD", "MONTO", "ESTADO"]
    for i, col in enumerate(cols):
        lbl = ctk.CTkLabel(table_head, text=col, font=("Inter", 11, "bold"), text_color="#4B5563", width=150 if i < 2 else 100)
        lbl.pack(side="left", padx=10, expand=True)

