def editar_perfil(usuario, ventana_padre):
    ventana_editar = ctk.CTkToplevel()
    ventana_editar.title("Editar Perfil")
    ventana_editar.geometry("350x350")
    ventana_editar.configure(fg_color=Color_fondo)
    ventana_editar.attributes("-topmost", True)

    ctk.CTkLabel(ventana_editar, text="Editar Perfil", font=("Arial", 18, "bold"), text_color=Color_texto_oscuro).pack(pady=20)

    entry_nombre = ctk.CTkEntry(ventana_editar, placeholder_text="Nuevo nombre", width=280)
    entry_nombre.pack(pady=5)
    entry_nombre.insert(0, usuario.Username)

    entry_correo = ctk.CTkEntry(ventana_editar, placeholder_text="Nuevo correo", width=280)
    entry_correo.pack(pady=5)
    entry_correo.insert(0, getattr(usuario, "correo", ""))

    entry_pass = ctk.CTkEntry(ventana_editar, placeholder_text="Nueva contraseña", show="*", width=280)
    entry_pass.pack(pady=5)

    ruta_foto = {"path": getattr(usuario, "foto", None) or getattr(usuario, "foto_perfil", None)}

    def seleccionar_foto():
        archivo = filedialog.askopenfilename(
            filetypes=[("Imágenes", "*.png *.jpg *.jpeg")]
        )
        if archivo:
            #Carpeta donde se guardarán las fotos 
            base_dir = os.path.dirname(os.path.abspath(__file__))
            carpeta_fotos = os.path.join(base_dir, "fotos_perfil")

            #Crear carpeta si no existe 
            os.makedirs(carpeta_fotos, exist_ok=True)

            #Nombre único para evitar sobreescribir 
            nombre_archivo = f"{usuario.idUsuario}_{os.path.basename(archivo)}"
            destino = os.path.join(carpeta_fotos, nombre_archivo)

            #Copiar imagen 
            shutil.copy(archivo, destino)

            #Guardar nueva ruta 
            ruta_foto["path"] = destino
            print("Foto guardada en:", destino)

    def guardar_cambios():
        usuario.actualizar_perfil(
            nuevo_Username=entry_nombre.get() or None,
            nuevo_correo=entry_correo.get() or None,
            nueva_contraseña=entry_pass.get() or None,
            nueva_foto=ruta_foto["path"]
        )
        sistema_back.guardar_csv_nuevo()
        ventana_editar.destroy()
        ventana_padre.destroy()
        abrir_panel_usuario(usuario)

    ctk.CTkButton(ventana_editar, text="📷 Seleccionar Foto",
                  fg_color=Color_boton_oscuro,
                  command=seleccionar_foto).pack(pady=10)
    ctk.CTkButton(ventana_editar, text="💾 Guardar Cambios",
                  fg_color=Color_boton_oscuro,
                  command=guardar_cambios).pack(pady=10)
    ctk.CTkButton(ventana_editar, text="Cancelar",
                  fg_color="transparent", text_color="red",
                  command=ventana_editar.destroy).pack(pady=5)
    

