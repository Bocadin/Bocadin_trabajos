def abrir_registro_consumo(admin_obj, ventana_padre):
    ventana_padre.withdraw()
    ventana_reg = ctk.CTkToplevel()
    ventana_reg.title("SAC - Registro de Consumo")
    ventana_reg.geometry("600x800")
    ventana_reg.configure(fg_color=Color_fondo)
    ventana_reg.attributes("-topmost", True)

    # Frame Principal 
    main_frame = ctk.CTkFrame(ventana_reg, fg_color="#C9E2CD", corner_radius=25)
    main_frame.pack(fill="both", expand=True, padx=25, pady=25)

    #Header
    header = ctk.CTkFrame(main_frame, fg_color="transparent")
    header.pack(fill="x", padx=30, pady=(20, 10))

    icon_head = cargar_icono("icono_consumo.png")
    if icon_head:
        icon_head.configure(size=(50, 50))
        ctk.CTkLabel(header, image=icon_head, text="").pack(side="left", padx=(0, 15))
    else:
        ctk.CTkLabel(header, text="📊", font=("Arial", 40)).pack(side="left", padx=(0, 15))

    title_txt = ctk.CTkFrame(header, fg_color="transparent")
    title_txt.pack(side="left")
    ctk.CTkLabel(title_txt, text="REGISTRO DE CONSUMOS", font=("Inter", 22, "bold"), text_color="#1B4332").pack(anchor="w")
    ctk.CTkLabel(title_txt, text="Gestión de servicios y cuotas", font=("Inter", 12), text_color="gray").pack(anchor="w")

    # Separador
    ctk.CTkFrame(main_frame, height=2, fg_color="#F1F5F9").pack(fill="x", padx=40, pady=10)

    ctk.CTkLabel(main_frame, text="RESIDENTE Y PERIODO", font=("Inter", 13, "bold"), text_color="#475569").pack(anchor="w", padx=45, pady=(10, 5))
    
    row_top = ctk.CTkFrame(main_frame, fg_color="transparent")
    row_top.pack(fill="x", padx=40)

    residentes = [f"{u.idUsuario} - {u.Username}" for u in sistema_back.usuarios.values() if u.tipoUsuario != "admin" and u.estado.lower() == "activo"]
    combo_residente = ctk.CTkComboBox(row_top, values=residentes if residentes else ["Sin residentes activos"], width=300, height=35)
    combo_residente.set("Seleccionar Residente")
    combo_residente.pack(side="left", padx=(0, 10))

    from datetime import datetime
    ent_fecha = ctk.CTkEntry(row_top, width=150, height=35, justify="center")
    ent_fecha.insert(0, datetime.now().strftime("%Y-%m-%d"))
    ent_fecha.pack(side="left")

    ctk.CTkLabel(main_frame, text="SELECCIONAR SERVICIO", font=("Inter", 13, "bold"), text_color="#475569").pack(anchor="w", padx=45, pady=(15, 5))
    
    scroll_servs = ctk.CTkScrollableFrame(main_frame, fg_color="#F8FAFC", height=130, orientation="horizontal", corner_radius=15)
    scroll_servs.pack(fill="x", padx=40)

    servicio_var = ctk.StringVar(value="")
    serv_buttons = {}

    def select_serv(sid):
        servicio_var.set(sid)
        for s_id, btn in serv_buttons.items():
            if btn.winfo_exists():
                if s_id == sid:
                    btn.configure(fg_color="#24A433", border_width=2, border_color="#24A433")
                else:
                    btn.configure(fg_color="white", border_width=1, border_color="#E2E8F0")
        on_servicio_select()
        refrescar_lectura_anterior()

    for s in sistema_back.servicios.values():
        f_btn = ctk.CTkFrame(scroll_servs, fg_color="white", corner_radius=12, width=110, height=90, border_width=1, border_color="#E2E8F0")
        f_btn.pack(side="left", padx=5, pady=5)
        f_btn.pack_propagate(False)
        serv_buttons[s.idServicio] = f_btn

        icon_s = cargar_icono(f"icono_{s.nombre.lower()}.png")
        if icon_s:
            ctk.CTkLabel(f_btn, image=icon_s, text="").pack(pady=(10, 2))
        else:
            ctk.CTkLabel(f_btn, text="📦", font=("Arial", 20)).pack(pady=(10, 2))
        
        ctk.CTkLabel(f_btn, text=s.nombre[:12], font=("Inter", 11, "bold"), text_color="black").pack()

        # Hacerlo clickable
        f_btn.bind("<Button-1>", lambda e, sid=s.idServicio: select_serv(sid))
        for child in f_btn.winfo_children():
            child.bind("<Button-1>", lambda e, sid=s.idServicio: select_serv(sid))

    lecturas_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    lecturas_frame.pack(fill="x", padx=40, pady=15)

    #Frame para entradas y resultado
    inputs_f = ctk.CTkFrame(lecturas_frame, fg_color="transparent")
    inputs_f.pack(side="left", fill="both", expand=True)

    ent_anterior = ctk.CTkEntry(inputs_f, placeholder_text="Lectura Anterior", height=40)
    ent_anterior.pack(fill="x", pady=5)

    ent_actual = ctk.CTkEntry(inputs_f, placeholder_text="Lectura Actual", height=40)
    ent_actual.pack(fill="x", pady=5)

    res_f = ctk.CTkFrame(lecturas_frame, fg_color="#F0FDF4", corner_radius=15, width=180)
    res_f.pack(side="right", padx=(20, 0), fill="y")
    res_f.pack_propagate(False)

    ctk.CTkLabel(res_f, text="CONSUMO", font=("Inter", 11, "bold"), text_color="#166534").pack(pady=(15, 0))
    lbl_consumo = ctk.CTkLabel(res_f, text="0.00", font=("Inter", 28, "bold"), text_color="#1B4332")
    lbl_consumo.pack(expand=True)

    def calcular_consumo(*args):
        try:
            ant_val = ent_anterior.get()
            act_val = ent_actual.get()
            ant = float(ant_val) if ant_val else 0
            act = float(act_val) if act_val else 0
            cons = max(0, act - ant)
            lbl_consumo.configure(text=f"{cons:.2f}")
        except:
            lbl_consumo.configure(text="0.00")

    def refrescar_lectura_anterior(*args):
        try:
            res_val = combo_residente.get()
            if " - " in res_val:
                res_id = res_val.split(" - ")[0]
                serv_id = servicio_var.get()
                if serv_id:
                    ultima = sistema_back.obtener_ultima_lectura(res_id, serv_id)
                    ent_anterior.delete(0, "end")
                    ent_anterior.insert(0, f"{ultima:.2f}")
                    calcular_consumo()
        except Exception as e:
            print(f"Error refrescar lectura: {e}")

    # Forzar actualización al cambiar residente
    combo_residente.configure(command=refrescar_lectura_anterior)

    def on_servicio_select():
        s_id = servicio_var.get()
        if s_id in sistema_back.servicios:
            s = sistema_back.servicios[s_id]
            if s.tipo == "fijo":
                ent_anterior.pack_forget()
                ent_actual.pack_forget()
                lbl_consumo.configure(text=f"${s.tarifa:.2f}")
            else:
                ent_anterior.pack(fill="x", pady=5)
                ent_actual.pack(fill="x", pady=5)
                calcular_consumo()

    ent_anterior.bind("<KeyRelease>", calcular_consumo)
    ent_actual.bind("<KeyRelease>", calcular_consumo)

    #Botones
    btn_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    btn_frame.pack(fill="x", side="bottom", pady=20, padx=40)

    def guardar_consumo():
        try:
            res_id = combo_residente.get().split(" - ")[0]
            serv_id = servicio_var.get()
            s = sistema_back.servicios.get(serv_id)
            if not s:
                mostrar_error("Seleccione un servicio.")
                return

            if s.tipo == "fijo":
                cons = 1.0
            else:
                ant = float(ent_anterior.get())
                act = float(ent_actual.get())
                cons = act - ant

            if serv_id and res_id and res_id not in ("Sin residentes", "Seleccionar Residente"):
                lect_actual = float(ent_actual.get() or 0) if s.tipo != "fijo" else 0
                sistema_back.registrar_consumo(cons, res_id, serv_id, ent_fecha.get(), lect_actual)
                mostrar_exito()
                ventana_reg.destroy()
                ventana_padre.deiconify()
            else:
                mostrar_error("Datos incompletos.")
        except Exception as e:
            mostrar_error("Verifique lecturas.")

    ctk.CTkButton(btn_frame, text="REGISTRAR CONSUMO", fg_color=Color_boton_oscuro, 
                   height=45, font=("Inter", 15, "bold"), command=guardar_consumo).pack(fill="x")
    
    ctk.CTkButton(btn_frame, text="REGRESAR", fg_color="#8B0000", text_color="white", 
                   command=lambda: [ventana_reg.destroy(), ventana_padre.deiconify()]).pack(fill="x", pady=(10, 0))

