    table_container = ctk.CTkFrame(historial_frame, fg_color="transparent")
    table_container.pack(fill="both", expand=True, padx=20, pady=(0, 20))

    # Header de tabla
    table_head = ctk.CTkFrame(table_container, fg_color="#F9FAFB", height=40)
    table_head.pack(fill="x")
    cols = ["FECHA", "SERVICIO", "CANTIDAD", "MONTO", "ESTADO"]
    for i, col in enumerate(cols):
        lbl = ctk.CTkLabel(table_head, text=col, font=("Inter", 11, "bold"), text_color="#4B5563", width=150 if i < 2 else 100)
        lbl.pack(side="left", padx=10, expand=True)

    scroll_table = ctk.CTkScrollableFrame(table_container, fg_color="transparent", height=250)
    scroll_table.pack(fill="both", expand=True)

    def cargar_tabla_consumos(*args):
        for w in scroll_table.winfo_children():
            w.destroy()
        
        filtro = combo_filtro_serv.get()
        mis_consumos = [c for c in sistema_back.consumos.values() if str(c.usuario_id) == str(usuario_obj.idUsuario)]
        
        for c in reversed(mis_consumos):
            serv = sistema_back.servicios.get(c.servicio_id)
            nom_serv = serv.nombre if serv else "Desconocido"
            
            if filtro != "Todos" and nom_serv != filtro:
                continue

            row = ctk.CTkFrame(scroll_table, fg_color="transparent", height=40)
            row.pack(fill="x", pady=2)
            
            ctk.CTkLabel(row, text=c.fecha, font=("Inter", 11), width=150).pack(side="left", padx=10, expand=True)
            ctk.CTkLabel(row, text=nom_serv, font=("Inter", 11), width=150).pack(side="left", padx=10, expand=True)
            ctk.CTkLabel(row, text=f"{c.cantidad}", font=("Inter", 11), width=100).pack(side="left", padx=10, expand=True)
            ctk.CTkLabel(row, text=f"${c.total(sistema_back):.2f}", font=("Inter", 11, "bold"), width=100).pack(side="left", padx=10, expand=True)
            
            est_color = "#059669" if c.estado == "pagado" else "#DC2626"
            ctk.CTkLabel(row, text=c.estado.upper(), font=("Inter", 10, "bold"), text_color=est_color, width=100).pack(side="left", padx=10, expand=True)

    combo_filtro_serv.configure(command=cargar_tabla_consumos)
    cargar_tabla_consumos()

