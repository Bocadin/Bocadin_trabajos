def abrir_panel_usuario(usuario_obj):
    ventana_panel = ctk.CTkToplevel()
    ventana_panel.title(f"Panel de Control - Sistema SAC")
    ventana_panel.geometry("950x650")
    ventana_panel.configure(fg_color=Color_fondo)
    
    # Fuentes
    font_title = ("Inter", 28, "bold")
    font_subtitle = ("Inter", 16, "bold")
    font_card_title = ("Inter", 12, "bold")
    font_card_value = ("Inter", 24, "bold")
    font_sidebar = ("Inter", 13)
    
    # barra lateral
    sidebar = ctk.CTkFrame(ventana_panel, fg_color="#C9E2CD", width=250, corner_radius=0)
    sidebar.pack(side="left", fill="y")
    sidebar.pack_propagate(False)

    user_frame = ctk.CTkFrame(sidebar, fg_color="transparent")
    user_frame.pack(pady=40, padx=20, fill="x")

    # Foto de perfil
    foto_path = getattr(usuario_obj, "foto_perfil", None)
    
    try:
        if foto_path and os.path.exists(foto_path):
            img_pil = Image.open(foto_path)
            img = ctk.CTkImage(img_pil, size=(150, 150))
            lbl_foto = ctk.CTkLabel(user_frame, image=img, text="")
            lbl_foto.pack(pady=10)
        else:
            raise FileNotFoundError
    except:
        ctk.CTkLabel(user_frame, text="👤", font=("Arial", 60)).pack(pady=10)

    ctk.CTkLabel(user_frame, text=usuario_obj.Username, font=("Inter", 20, "bold"), text_color=Color_boton_oscuro).pack()
    
    status_frame = ctk.CTkFrame(user_frame, fg_color="transparent")
    status_frame.pack(pady=5)
    ctk.CTkLabel(status_frame, text="●", text_color="#10B981", font=("Arial", 12)).pack(side="left")
    ctk.CTkLabel(status_frame, text=" Propietario Activo", font=("Inter", 12), text_color="#10B981").pack(side="left")

    # frame botones
    nav_frame = ctk.CTkFrame(sidebar, fg_color="transparent")
    nav_frame.pack(fill="both", expand=True, padx=10)

    def on_nav_click(opcion):
        if opcion == "Editar Perfil":
            editar_perfil(usuario_obj, ventana_panel)
        elif opcion == "Recibos":
            abrir_mis_recibos(usuario_obj)
        elif opcion == "Pagos":
            abrir_ventana_pagos(usuario_obj)
        elif opcion == "Reportes":
            abrir_reportes_usuario(usuario_obj)

    botones_nav = [
        ("👤 Editar Perfil", "Editar Perfil"),
        ("📄 Mis Recibos", "Recibos"),
        ("💳 Realizar Pagos", "Pagos"),
        ("⚠️ Reportes", "Reportes")
    ]

    for icono_texto, cmd_name in botones_nav:
        btn = ctk.CTkButton(nav_frame, text=icono_texto, anchor="w", fg_color = Color_boton_oscuro, 
                            text_color="White", hover_color="#1B1F28", height=45,
                            font=font_sidebar, command=lambda c=cmd_name: on_nav_click(c))
        btn.pack(fill="x", pady=5)

    # Logout Button
    logout_btn = ctk.CTkButton(sidebar, text="Cerrar Sesión", fg_color="#8B0000", text_color="#FFFFFF",
                               hover_color="#520505", height=40, font=("Inter", 13, "bold"),
                               command=lambda: (ventana_panel.destroy(), ventana_principal.deiconify()))
    logout_btn.pack(side="bottom", fill="x", padx=20, pady=20)

    content = ctk.CTkFrame(ventana_panel, fg_color="transparent")
    content.pack(side="right", fill="both", expand=True, padx=40, pady=40)

    ctk.CTkLabel(content, text=f"Bienvenido, {usuario_obj.Username}", font=font_title, text_color=Color_boton_oscuro).pack(anchor="w", pady=(0, 30))

    # Parte de información de fecha pago
    pago_info = usuario_obj.obtener_informacion_pago(sistema_back)
    
    user_pago = ctk.CTkFrame(content, fg_color="white", corner_radius=15)
    user_pago.pack(fill="x", pady=(0, 20))
    
    user_pago.columnconfigure(0, weight=1)
    user_pago.columnconfigure(1, weight=0)

    txt_frame = ctk.CTkFrame(user_pago, fg_color="transparent")
    txt_frame.grid(row=0, column=0, padx=30, pady=25, sticky="w")
    
    ctk.CTkLabel(txt_frame, text="PRÓXIMO VENCIMIENTO", font=font_card_title, text_color="gray").pack(anchor="w")
    ctk.CTkLabel(txt_frame, text=pago_info["fecha"], font=font_card_value, text_color=Color_boton_oscuro).pack(anchor="w")

    monto_info= ctk.CTkLabel(user_pago, text=pago_info["monto"], font=("Inter", 32, "bold"), text_color="#16A34A")
    monto_info.grid(row=0, column=1, padx=40, pady=25, sticky="e")

    user_frame_info = ctk.CTkFrame(content, fg_color="white", corner_radius=15)
    user_frame_info.pack(fill="both", expand=True)

    ctk.CTkLabel(user_frame_info, text="Información del Residente", font=font_subtitle, text_color=Color_boton_oscuro).pack(anchor="w", padx=30, pady=(25, 15))

    details_frame = ctk.CTkFrame(user_frame_info, fg_color="transparent")
    details_frame.pack(fill="x", padx=30)

    def add_detail(label, value):
        row = ctk.CTkFrame(details_frame, fg_color="transparent")
        row.pack(fill="x", pady=8)
        ctk.CTkLabel(row, text=label, font=("Inter", 13), text_color="gray", width=120, anchor="w").pack(side="left")
        ctk.CTkLabel(row, text=value, font=("Inter", 13, "bold"), text_color=Color_boton_oscuro).pack(side="left")

    datos = usuario_obj.consultar_perfil()
    add_detail("ID de Usuario:", datos["idUsuario"])
    add_detail("Nombre Completo:", datos["nombre_completo"])
    add_detail("Dirección:", datos["direccion"])
    add_detail("Teléfono:", datos["telefono"])
    
    correo = getattr(usuario_obj, "correo", "No registrado")
    add_detail("Correo:", correo)

