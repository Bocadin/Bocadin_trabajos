def safe_report_callback_exception(exc, val, tb):
    # Ignorar errores inofensivos de Tkinter relacionados con la destrucción de widgets enfocados
    error_msg = str(val)
    if "bad window path name" in error_msg or "invalid command name" in error_msg:
        return
    import traceback
    traceback.print_exception(exc, val, tb)

