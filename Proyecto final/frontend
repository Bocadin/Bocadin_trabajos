    main_frame = ctk.CTkFrame(ventana_servicios, fg_color="#F4FDF4", border_color="#196D39", border_width=4, corner_radius=15)
    main_frame.pack(fill="both", expand=True, padx=20, pady=20)

    title_bar = ctk.CTkFrame(main_frame, fg_color="#196D39", corner_radius=10, height=40)
    title_bar.pack(fill="x", padx=0, pady=0)

    ctk.CTkButton(title_bar, text="X", fg_color="white", text_color="#196D39", width=30, height=20, font=("Arial", 12, "bold"),
                  command=ventana_servicios.destroy).pack(side="right", padx=10, pady=10)
    
    #Cuerpo principal dividido en izquierda y derecha 
    content_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    content_frame.pack(fill="both", expand=True, padx=10, pady=10)

    content_frame.grid_columnconfigure(0, weight=3)
    content_frame.grid_columnconfigure(1, weight=1)
    content_frame.grid_rowconfigure(0, weight=1)

    # Panel Izquierdo
    panel_izq = ctk.CTkFrame(content_frame, fg_color="transparent")
    panel_izq.grid(row=0, column=0, sticky="nsew", padx=(0, 10))

    filtros_frame = ctk.CTkFrame(panel_izq, fg_color="transparent")
    filtros_frame.pack(fill="x", pady=(10, 20))

    f1_f2_frame = ctk.CTkFrame(filtros_frame, fg_color="transparent")
    f1_f2_frame.pack(fill="x")

    filtro_1 = ctk.CTkComboBox(f1_f2_frame, values=["Tipo: Todos", "Tipo: Medido", "Tipo: Fijo"],
                               fg_color="#3B9C3D", text_color="white", button_color="#3B9C3D", border_width=0, height=30)
    filtro_1.pack(side="left", padx=5, expand=True, fill="x")

    filtro_2 = ctk.CTkComboBox(f1_f2_frame, values=["Mov: Todos", "Mov: Pendientes", "Mov: Pagados"],
                               fg_color="#7A9C7A", text_color="white", button_color="#7A9C7A", border_width=0, height=30)
    filtro_2.pack(side="left", padx=5, expand=True, fill="x")

    filtro_3 = ctk.CTkEntry(filtros_frame, placeholder_text="Buscar servicio...",
                            fg_color="#D1D5DB", text_color="black", border_width=0, height=30, justify="center")
    filtro_3.pack(fill="x", padx=5, pady=(10, 0))

    servicios_frame = ctk.CTkFrame(panel_izq, fg_color="transparent")
    servicios_frame.pack(fill="both", expand=True)

    # Panel Derecho (Botones y movimientos)
    panel_derecho = ctk.CTkFrame(content_frame, fg_color="transparent")
    panel_derecho.grid(row=0, column=1, sticky="nsew")
    
    #Separador vertical
    separador = ctk.CTkFrame(content_frame, fg_color="#196D39", width=3)
    separador.grid(row=0, column=0, sticky="nse", padx=0, pady=10)

    servicio_seleccionado = ctk.StringVar(value="")

    def seleccionar_servicio(s_id):
        #Guarda el ID del servicio seleccionado y recarga la cuadricula para actualizar bordes
        servicio_seleccionado.set(s_id)
        cargar_servicios()

    def cargar_servicios(*args):
        #Limpia la vista y vuelve a generar los botones de los servicios
        for widget in servicios_frame.winfo_children():
            widget.destroy()

        col = 0
        row = 0
        colores = [
            ("#C9E4FF", "#3B82F6"),
            ("#FFF9C4", "#F59E0B"),
            ("#D7CCC8", "#8D6E63"),
            ("#FFCDD2", "#EF5350"),
            ("#C8E6C9", "#4CAF50")
        ]

        tipo_filtro = filtro_1.get()
        busqueda = filtro_3.get().lower()

        idx = 0
        for s_id, s in sistema_back.servicios.items():
            if tipo_filtro == "Tipo: Medido" and s.tipo != "medido":
                continue
            if tipo_filtro == "Tipo: Fijo" and s.tipo != "fijo":
                continue
            if busqueda and busqueda not in s.nombre.lower():
                continue

            bg_color, border_color = colores[idx % len(colores)]
            idx += 1
           
            #Resaltar si esta selccionado
            is_sel = (servicio_seleccionado.get() == s_id)
            current_border = "#000000" if is_sel else border_color
            b_width = 5 if is_sel else 3

            btn = ctk.CTkButton(servicios_frame, text=f"{s.nombre.upper()}\n${s.tarifa}",
                                font=("Consolas", 18, "bold"), text_color="black",
                                fg_color=bg_color, hover_color=bg_color,
                                border_color=current_border, border_width=b_width,
                                width=150, height=100, corner_radius=20,
                                command=lambda id_s=s_id: seleccionar_servicio(id_s))
            btn.grid(row=row, column=col, padx=15, pady=15, sticky="nsew")
            col += 1
            if col > 1:
                col = 0
                row += 1

    filtro_1.configure(command=cargar_servicios)
    filtro_3.bind("<KeyRelease>", cargar_servicios)
    cargar_servicios()

    def abrir_form_servicio(es_editar=False):
        if es_editar and not servicio_seleccionado.get():
            mostrar_error("Selecciona un servicio para editar.")
            return

        form = ctk.CTkToplevel(ventana_servicios)
        form.title("Editar Servicio" if es_editar else "Nuevo Servicio")
        form.geometry("300x350")
        form.configure(fg_color=Color_fondo)
        form.attributes("-topmost", True)

        ctk.CTkLabel(form, text="Editar Servicio" if es_editar else "Nuevo Servicio", font=("Arial", 16, "bold")).pack(pady=10)

        ent_nombre = ctk.CTkEntry(form, placeholder_text="Nombre (Ej. Agua)")
        ent_nombre.pack(pady=10)

        tipo_var = ctk.StringVar(value="medido")
        ctk.CTkRadioButton(form, text="Medido (por unidad)", variable=tipo_var, value="medido").pack(pady=5)
        ctk.CTkRadioButton(form, text="Cuota Fija", variable=tipo_var, value="fijo").pack(pady=5)

        ent_tarifa = ctk.CTkEntry(form, placeholder_text="Tarifa ($)")
        ent_tarifa.pack(pady=10)

        if es_editar:
            s_edit = sistema_back.servicios[servicio_seleccionado.get()]
            ent_nombre.insert(0, s_edit.nombre)
            tipo_var.set(s_edit.tipo)
            ent_tarifa.insert(0, str(s_edit.tarifa))

        def guardar():
            nombre = ent_nombre.get()
            tipo = tipo_var.get()
            tarifa = ent_tarifa.get()
            if nombre and tarifa:
                try:
                    float(tarifa)
                    if es_editar:
                        sistema_back.editar_servicio(servicio_seleccionado.get(), nombre, tipo, tarifa)
                    else:
                        sistema_back.crear_servicio(nombre, tipo, tarifa)
                    cargar_servicios()
                    form.destroy()
                except:
                    mostrar_error("Tarifa debe ser número")

        ctk.CTkButton(form, text="Guardar", fg_color=Color_boton_oscuro, command=guardar).pack(pady=20)

    ctk.CTkButton(panel_derecho, text="+ servicios", fg_color="#196D39", font=("Arial", 14, "bold"),
                  corner_radius=10, height=40, command=lambda: abrir_form_servicio(False)).pack(pady=(20, 10), padx=20, fill="x")

    botones_gestion_frame = ctk.CTkFrame(panel_derecho, fg_color="transparent")
    botones_gestion_frame.pack(fill="x", padx=20, pady=10)

    ctk.CTkButton(botones_gestion_frame, text="Editar", fg_color="#9CA3AF", font=("Arial", 14, "bold"),
                  text_color="white", corner_radius=10, height=35,
                  command=lambda: abrir_form_servicio(True)).pack(side="left", expand=True, padx=(0, 5), fill="x")

    mov_seleccionado = ctk.StringVar(value="")

    def marcar_como_pagado():
        c_id = mov_seleccionado.get()
        if c_id:
            sistema_back.marcar_consumo_pagado(c_id)
            cargar_movimientos()
            mostrar_exito()
        else:
            mostrar_error("Selecciona un movimiento.")

    def eliminar_movimiento():
        c_id = mov_seleccionado.get()
        if c_id:
            sistema_back.eliminar_consumo(c_id)
            cargar_movimientos()
            mostrar_exito()
        else:
            mostrar_error("Selecciona un movimiento.")

    ctk.CTkButton(botones_gestion_frame, text="Pagado", fg_color="#3B82F6", font=("Arial", 14, "bold"),
                  text_color="white", corner_radius=10, height=35, command=marcar_como_pagado, width=100).pack(side="left", expand=True, padx=5, fill="x")
    ctk.CTkButton(botones_gestion_frame, text="Eliminar", fg_color="#EF4444", font=("Arial", 14, "bold"),
                  text_color="white", corner_radius=10, height=35, command=eliminar_movimiento, width=100).pack(side="right", expand=True, padx=(0, 5), fill="x")

    mov_frame = ctk.CTkFrame(panel_derecho, fg_color="#DCFCE7", corner_radius=15)
    mov_frame.pack(fill="both", expand=True, padx=20, pady=(10, 20))
    ctk.CTkLabel(mov_frame, text="movimientos", font=("Arial", 14, "bold"), text_color="black").pack(pady=10)

    scroll_mov = ctk.CTkScrollableFrame(mov_frame, fg_color="transparent")
    scroll_mov.pack(fill="both", expand=True, padx=5, pady=5)

    def cargar_movimientos(*args):
        # Muestra el historial de consumos registrados, aplicando el filtro de Pagados/Pendientes
        for widget in scroll_mov.winfo_children():
            widget.destroy()

        filtro_mov = filtro_2.get()
        movimientos = list(sistema_back.consumos.values())

        if filtro_mov == "Mov: Pagados":
            movimientos = [c for c in movimientos if c.estado == "pagado"]
        elif filtro_mov == "Mov: Pendientes":
            movimientos = [c for c in movimientos if c.estado == "pendiente"]

        for c in reversed(movimientos[-15:]):
            nom_serv = sistema_back.servicios[c.servicio_id].nombre if c.servicio_id in sistema_back.servicios else "Servicio"
            nom_user = sistema_back.usuarios[c.usuario_id].Username if c.usuario_id in sistema_back.usuarios else "Desconocido"
            estado_texto = "✅" if c.estado == "pagado" else "⏳"
            color_texto = "#9CA3AF" if c.estado == "pagado" else "#1F2937"

            ctk.CTkRadioButton(scroll_mov,
                               text=f"{estado_texto} {nom_serv} - {nom_user}: ${c.total(sistema_back):.2f}",
                               variable=mov_seleccionado, value=c.idConsumo,
                               font=("Arial", 12), text_color=color_texto).pack(pady=5, anchor="w")

    filtro_2.configure(command=cargar_movimientos)
    cargar_movimientos()

    ctk.CTkButton(panel_derecho, text="", fg_color="#196D39", width=30, height=30, corner_radius=15, hover=False).pack(side="right", padx=10, pady=10)

