def editar_perfil(usuario, ventana_padre, callback_refresh=None):
    # Ventana de edición de perfil para el residente.
    # Permite modificar el nombre de usuario, correo, contraseña y foto de perfil.
    # Recibe un callback opcional para notificar y refrescar la vista del panel padre.
    ventana_editar = ctk.CTkToplevel()
    ventana_editar.title("Editar Perfil")
    ventana_editar.geometry("800x550")
    ventana_editar.configure(fg_color=Color_fondo)
    ventana_editar.attributes("-topmost", True)

    # Encabezado de la ventana con icono de edición
    header = ctk.CTkFrame(ventana_editar, fg_color="transparent")
    header.pack(fill="x", padx=40, pady=(30, 10))
    
    icon_edit_head = cargar_icono("edit_icon.png")
    if icon_edit_head:
        icon_edit_head.configure(size=(40, 40))
        ctk.CTkLabel(header, image=icon_edit_head, text="").pack(side="left", padx=(0, 15))
    
    ctk.CTkLabel(header, text="EDITAR PERFIL", font=("Inter", 24, "bold"), text_color="#040404").pack(side="left")

    # Contenedor principal de la tarjeta de edición
    card = ctk.CTkFrame(ventana_editar, fg_color="white", corner_radius=25)
    card.pack(fill="both", expand=True, padx=40, pady=(10, 40))

    # Configuración de columnas para la disposición de elementos (Foto izquierda, Formulario derecha)
    card.grid_columnconfigure(0, weight=1) 
    card.grid_columnconfigure(1, weight=0) 
    card.grid_columnconfigure(2, weight=1) 
    card.grid_rowconfigure(0, weight=1)

    left_side = ctk.CTkFrame(card, fg_color="transparent")
    left_side.grid(row=0, column=0, sticky="nsew", padx=20, pady=20)

    # Contenedor circular/redondeado para la previsualización de la foto de perfil
    photo_container = ctk.CTkFrame(left_side, fg_color="#C9E2CD", width=180, height=180, corner_radius=90)
    photo_container.pack(pady=(20, 15))
    photo_container.pack_propagate(False)

    curr_photo_path = getattr(usuario, "foto_perfil", None) or getattr(usuario, "foto", None)
    if curr_photo_path and os.path.exists(curr_photo_path):
        try:
            img_p = ctk.CTkImage(Image.open(curr_photo_path), size=(180, 180))
            lbl_p = ctk.CTkLabel(photo_container, image=img_p, text="")
            lbl_p.pack(expand=True)
        except:
            ctk.CTkLabel(photo_container, text="📷", font=("Arial", 60), text_color="#14532D").pack(expand=True)
    else:
        ctk.CTkLabel(photo_container, text="📷", font=("Arial", 60), text_color="#14532D").pack(expand=True)

    ruta_foto = {"path": curr_photo_path}

    def seleccionar_foto():
        # Cuadro de diálogo para seleccionar la foto desde el explorador del usuario
        archivo = filedialog.askopenfilename(filetypes=[("Imágenes", "*.png *.jpg *.jpeg")])
        if archivo:
            base_dir = os.path.dirname(os.path.abspath(__file__))
            carpeta_fotos = os.path.join(base_dir, "fotos_perfil")
            os.makedirs(carpeta_fotos, exist_ok=True)
            nombre_archivo = f"{usuario.idUsuario}_{os.path.basename(archivo)}"
            destino = os.path.join(carpeta_fotos, nombre_archivo)
            shutil.copy(archivo, destino)
            ruta_foto["path"] = destino
            # Actualiza dinámicamente la previsualización de la foto seleccionada
            try:
                img_new = ctk.CTkImage(Image.open(destino), size=(180, 180))
                for widget in photo_container.winfo_children(): widget.destroy()
                ctk.CTkLabel(photo_container, image=img_new, text="").pack(expand=True)
            except: pass

    btn_sel = ctk.CTkButton(left_side, text="📷 Seleccionar Foto", fg_color="#162440", text_color="white",
                             height=45, corner_radius=10, font=("Inter", 14, "bold"), command=seleccionar_foto)
    btn_sel.pack(fill="x", padx=20)

    # Línea divisoria central
    sep = ctk.CTkFrame(card, width=2, fg_color="#E5E7EB")
    sep.grid(row=0, column=1, sticky="ns", pady=40)

    right_side = ctk.CTkFrame(card, fg_color="transparent")
    right_side.grid(row=0, column=2, sticky="nsew", padx=30, pady=30)

    def create_input_row(parent, icon_name, placeholder, initial_val="", is_pass=False):
        # Fila contenedora para campos de entrada estilizados con iconos descriptivos
        row = ctk.CTkFrame(parent, fg_color="white", border_color="#E5E7EB", border_width=1, height=50, corner_radius=10)
        row.pack(fill="x", pady=10)
        row.pack_propagate(False)
        
        icon = cargar_icono(icon_name)
        if icon:
            icon.configure(size=(20, 20))
            ctk.CTkLabel(row, image=icon, text="", width=40).pack(side="left", padx=(10, 5))
        else:
            chars = {"icono_usuario.png": "👤", "icono_email.png": "📧", "icono_password.png": "🔒"}
            ctk.CTkLabel(row, text=chars.get(icon_name, "•"), font=("Arial", 18), text_color="#14532D", width=40).pack(side="left", padx=(10, 5))
        
        entry = ctk.CTkEntry(row, placeholder_text=placeholder, fg_color="transparent", border_width=0, 
                             font=("Inter", 13), show="*" if is_pass else "")
        entry.pack(side="left", fill="both", expand=True, padx=5)
        if initial_val: entry.insert(0, initial_val)
        
        if is_pass:
            def toggle():
                if entry.cget("show") == "*": entry.configure(show="")
                else: entry.configure(show="*")
            icon_eye = cargar_icono("icono_ojo.png")
            if icon_eye:
                icon_eye.configure(size=(20, 20))
                ctk.CTkButton(row, image=icon_eye, text="", width=30, fg_color="transparent", hover=False, command=toggle).pack(side="right", padx=10)
        
        return entry

    entry_nombre = create_input_row(right_side, "icono_usuario.png", "Usuario", usuario.Username)
    entry_correo = create_input_row(right_side, "icono_email.png", "Correo Electrónico", getattr(usuario, "correo", ""))
    entry_pass = create_input_row(right_side, "icono_password.png", "Nueva contraseña", "", is_pass=True)

    def guardar_cambios():
        # Aplica los cambios editados en el perfil de usuario a través del backend
        usuario.actualizar_perfil(
            nuevo_Username=entry_nombre.get() or None,
            nuevo_correo=entry_correo.get() or None,
            nueva_contraseña=entry_pass.get() or None,
            nueva_foto=ruta_foto["path"]
        )
        # Sincroniza y persiste los cambios de forma local en el archivo CSV
        sistema_back.guardar_csv_nuevo()
        # Redirige el foco de forma segura al panel padre antes de destruir
        ventana_padre.deiconify()
        ventana_padre.focus_force()
        # Destruye la ventana actual de edición
        ventana_editar.destroy()
        # Invoca el callback de actualización/refresco si se encuentra especificado
        if callback_refresh:
            callback_refresh()

    def cancelar():
        # Redirige el foco de forma segura al panel padre antes de destruir
        ventana_padre.deiconify()
        ventana_padre.focus_force()
        ventana_editar.destroy()

    ventana_editar.protocol("WM_DELETE_WINDOW", cancelar)

    btn_save = ctk.CTkButton(right_side, text="💾 Guardar Cambios", fg_color="#14532D", hover_color="#0F3D21",
                             height=50, corner_radius=12, font=("Inter", 15, "bold"), command=guardar_cambios)
    btn_save.pack(fill="x", pady=(20, 5))

    btn_cancel = ctk.CTkButton(right_side, text="🗑️ Cancelar", fg_color="#8B0000", text_color="white", border_width=1, hover_color="#EFBABA",
                               height=50, corner_radius=12, font=("Inter", 15, "bold"), 
                               command=cancelar)
    btn_cancel.pack(fill="x", pady=5)


