def abrir_generar_recibo(admin_obj):
    # Ventana para generar recibos en base a los consumos pendientes de un inquilino
    ventana_recibo = ctk.CTkToplevel(ventana_principal)
    ventana_recibo.title("Generar Recibo")
    ventana_recibo.geometry("500x400")
    ventana_recibo.configure(fg_color="white")
    ventana_recibo.attributes("-topmost", True)

    main_frame = ctk.CTkFrame(ventana_recibo, fg_color="#F4FDF4", border_color="#196D39", border_width=3, corner_radius=15)
    main_frame.pack(fill="both", expand=True, padx=20, pady=20)

    title_bar = ctk.CTkFrame(main_frame, fg_color="#196D39", corner_radius=10, height=30)
    title_bar.pack(fill="x")
    ctk.CTkButton(title_bar, text="X", fg_color="white", text_color="#196D39", width=20, height=20,
                  font=("Arial", 12, "bold"), command=ventana_recibo.destroy).pack(side="right", padx=5, pady=5)

    content_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    content_frame.pack(fill="both", expand=True, padx=20, pady=10)

    ent_periodo = ctk.CTkEntry(content_frame, placeholder_text="Fecha / Periodo",
                               fg_color="#D1D5DB", text_color="black", border_width=0, justify="center")
    ent_periodo.pack(fill="x", pady=(10, 20))

    botones_frame = ctk.CTkFrame(content_frame, fg_color="transparent")
    botones_frame.pack(fill="x", pady=10)

    tipo_var = ctk.StringVar(value="individual")
    residentes = [f"{u.idUsuario} - {u.Username}" for u in sistema_back.usuarios.values() if u.tipoUsuario != "admin"]
    combo_residente = ctk.CTkComboBox(content_frame, values=residentes if residentes else ["Sin residentes"], width=300)
    combo_residente.set("Seleccione Residente")

    def on_tipo_change():
        if tipo_var.get() == "individual":
            combo_residente.pack(pady=10)
        else:
            combo_residente.pack_forget()

    btn_ind = ctk.CTkRadioButton(botones_frame, text="Individual", variable=tipo_var, value="individual",
                                 font=("Arial", 16, "bold"), text_color="black", fg_color="#196D39", command=on_tipo_change)
    btn_ind.pack(side="left", padx=(30, 20))
    btn_gen = ctk.CTkRadioButton(botones_frame, text="General", variable=tipo_var, value="general",
                                 font=("Arial", 16, "bold"), text_color="black", fg_color="#196D39", command=on_tipo_change)
    btn_gen.pack(side="right", padx=(20, 30))

    on_tipo_change()

    ctk.CTkFrame(content_frame, height=2, fg_color="#196D39").pack(fill="x", pady=15)

    def obtener_pendientes():
        # Busca en la base de datos todos los consumos (movimientos) que estén en estado "pendiente" para el inquilino
        pendientes = []
        if tipo_var.get() == "individual":
            res_id = combo_residente.get().split(" - ")[0]
            if res_id and res_id not in ("Sin residentes", "Seleccione Residente"):
                pendientes = [c for c in sistema_back.consumos.values() if c.usuario_id == res_id and c.estado == "pendiente"]
        else:
            pendientes = [c for c in sistema_back.consumos.values() if c.estado == "pendiente"]
        return pendientes

    def mostrar_vista_previa():
        # Abre un pequeño recuadro previsualizando el total del recibo
        pendientes = obtener_pendientes()
        total = sum(c.total(sistema_back) for c in pendientes)

        vp = ctk.CTkToplevel(ventana_recibo)
        vp.title("Vista Previa (Recibo)")
        vp.geometry("400x300")
        vp.configure(fg_color="white")
        vp.attributes("-topmost", True)

        mf = ctk.CTkFrame(vp, fg_color="#F4FDF4", border_color="#196D39", border_width=3, corner_radius=15)
        mf.pack(fill="both", expand=True, padx=10, pady=10)

        info_frame = ctk.CTkFrame(mf, fg_color="#E5E7EB", corner_radius=15)
        info_frame.pack(fill="both", expand=True, padx=20, pady=20)

        detalles = (f"Información Recibo\n\nPeriodo: {ent_periodo.get()}\n"
                    f"Tipo: {tipo_var.get().capitalize()}\n\n"
                    f"Consumos pendientes: {len(pendientes)}\n"
                    f"Total estimado: ${total:.2f}")

        ctk.CTkLabel(info_frame, text=detalles, font=("Arial", 14), text_color="black").pack(expand=True)

    def imprimir():
        imp = ctk.CTkToplevel(ventana_recibo)
        imp.title("Imprimiendo")
        imp.geometry("250x150")
        imp.configure(fg_color="white")
        imp.attributes("-topmost", True)

        mf = ctk.CTkFrame(imp, fg_color="#F4FDF4", border_color="#196D39", border_width=3, corner_radius=10)
        mf.pack(fill="both", expand=True, padx=10, pady=10)
        ctk.CTkLabel(mf, text="🖨️ Imprimiendo", font=("Arial", 16, "bold"), text_color="black").pack(pady=(20, 10))
        ctk.CTkButton(mf, text="Aceptar", fg_color="white", border_color="#196D39",
                      border_width=2, text_color="black", command=imp.destroy).pack()

    def guardar():
        # Suma los consumos pendientes, crea el recibo en base de datos y marca esos consumos como pagados
        pendientes = obtener_pendientes()
        total = sum(c.total(sistema_back) for c in pendientes)

        if total <= 0:
            mostrar_error("No hay consumos pendientes.")
            return
        
        # Marcar los pendientes como pagados
        for c in pendientes:
            sistema_back.marcar_consumo_pagado(c.idConsumo)

        res_id = combo_residente.get().split(" - ")[0] if tipo_var.get() == "individual" else "varios"
        sistema_back.generar_recibo(usuario_id=res_id, periodo=ent_periodo.get(), total=total)
        mostrar_exito()
        ventana_recibo.destroy()
    ctk.CTkButton(content_frame, text="Vista Previa", fg_color="#196D39", font=("Arial", 14, "bold"), command=mostrar_vista_previa).pack(fill="x", pady=5)
    ctk.CTkButton(content_frame, text="Guardar", fg_color="#196D39", font=("Arial", 14, "bold"), command=guardar).pack(fill="x", pady=5)
    ctk.CTkButton(content_frame, text="Imprimir", fg_color="#196D39", font=("Arial", 14, "bold"), command=imprimir).pack(side="right", pady=10, padx=20)


