        rep_sel[0] = rep

        if fila_sel[0]:
            try:
                fila_sel[0].configure(fg_color="transparent")
            except:
                pass

        fila_sel[0] = fila

        fila.configure(fg_color="#EEF8EF")

        # Intentar buscar nombre real si nombre_reporta es un ID o es el nombre guardado
        quien_reporta = rep.nombre_reporta
        if rep.usuario_id in sistema_back.usuarios:
            user = sistema_back.usuarios[rep.usuario_id]
            if user.nombre_completo:
                quien_reporta = f"{user.nombre_completo} (ID: {rep.usuario_id})"
        
        info_str = (
            f"ID: #{rep.idReporte}\n"
            f"Reportado por: {quien_reporta}\n"
            f"Fecha: {rep.fecha}\n"
            f"Prioridad: {rep.prioridad}\n"
            f"Estado: {rep.estado}\n\n"
            f"DESCRIPCIÓN:\n"
            f"{rep.descripcion}"
        )
        
        lbl_detail_txt.configure(state="normal")
        lbl_detail_txt.delete("1.0", "end")
        lbl_detail_txt.insert("1.0", info_str)
        lbl_detail_txt.configure(state="disabled")
        
        mostrar_evidencias(rep)

    def cargar_tabla_reps(*args):
        for w in scroll_reps.winfo_children():
            w.destroy()
        filtro = ent_buscar.get().lower()

        icons_map = {
            "Mantenimiento": "🔧",
            "Limpieza": "🧹",
            "Seguridad": "🛡️",
            "Entrega de Paquete": "📦",
            "Reserva de Área Común": "🗓️"
        }

        mostrados = 0
        for r in sistema_back.reportes.values():
            if filtro and filtro not in r.fecha:
                continue
            mostrados += 1

            fila = ctk.CTkFrame(scroll_reps, fg_color="transparent", corner_radius=8, height=45)
            fila.pack(fill="x", padx=3, pady=2)
            fila.grid_columnconfigure(0, weight=3, uniform="cols")
            fila.grid_columnconfigure((1,2,3), weight=1, uniform="cols")

            ic = icons_map.get(r.tipo, "📝")

            lbl1 = ctk.CTkLabel(fila, text=f"{ic}  {r.titulo}", font=("Arial", 11), anchor="w")
            lbl1.grid(row=0, column=0, padx=10, sticky="w")

            lbl2 = ctk.CTkLabel(fila, text=r.fecha, font=("Arial", 11))
            lbl2.grid(row=0, column=1)

            lbl3 = ctk.CTkLabel(fila, text=f"🚩 {r.prioridad}", font=("Arial", 10, "bold"), text_color="#B8860B")
            lbl3.grid(row=0, column=2)

            estado_color = {
                "Pendiente": "#D32F2F",
                "En Proceso": "#F57C00",
                "Cerrado": "#2E7D32"
            }.get(r.estado, "gray")

            estado_frame = ctk.CTkFrame(fila, fg_color="#FFF5F5", corner_radius=15, border_width=1, border_color="#E5E5E5", width=95, height=26)

            estado_frame.grid(row=0, column=3)
            estado_frame.pack_propagate(False)

            ctk.CTkLabel(estado_frame, text=f"● {r.estado}", text_color=estado_color, font=("Arial", 9, "bold")).pack(expand=True)

            widgets = [
                fila, lbl1, lbl2, lbl3, estado_frame
            ]

            for w in widgets:
                w.bind(
                    "<Button-1>",
                    lambda e, rep=r, f=fila:
                    seleccionar(rep, f)
                )

        lbl_counts.configure(
            text=f"Mostrando {mostrados} reportes"
        )

    def editar_st():
        if not rep_sel[0]:
            return
        r = rep_sel[0]
        sts = ["Pendiente", "En Proceso", "Cerrado"]
        nxt = sts[(sts.index(r.estado) + 1) % 3]
        if sistema_back.editar_reporte_estado(r.idReporte, nxt):
            cargar_tabla_reps()
            refrescar_stats()

    def eliminar_rep_ui():
        if not rep_sel[0]:
            return
        if messagebox.askyesno(
            "Confirmar",
            f"¿Eliminar reporte {rep_sel[0].idReporte}?"
        ):
            sistema_back.eliminar_reporte(rep_sel[0].idReporte)
            rep_sel[0] = None
            cargar_tabla_reps()
            refrescar_stats()
            lbl_detail_txt.configure(state="normal")
            lbl_detail_txt.delete("1.0", "end")
            lbl_detail_txt.insert("1.0", "Seleccione un reporte")
            lbl_detail_txt.configure(state="disabled")
            for w in photos_container.winfo_children():
                w.destroy()

    btn_edit_st.configure(command=editar_st)
    btn_delete.configure(command=eliminar_rep_ui)
    ent_buscar.bind("<KeyRelease>", cargar_tabla_reps)

    cargar_tabla_reps()

