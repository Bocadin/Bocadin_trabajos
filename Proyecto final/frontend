        for widget in tabla_residentes.winfo_children():

            if widget != header:
                widget.destroy()

        texto_busqueda = entry_busqueda.get().lower()
        tipo_filtro = filtros.get()
        estado_filtro = estado_var.get()

        for u in sistema_back.usuarios.values():

            if u.tipoUsuario == "admin":
                continue

            if texto_busqueda:

                if (
                    texto_busqueda not in u.Username.lower()
                    and texto_busqueda not in str(u.idUsuario)
                ):
                    continue

            if tipo_filtro != "Todos":

                if (
                    tipo_filtro == "Propietarios"
                    and u.tipoUsuario != "Propietario"
                ):
                    continue

                if (
                    tipo_filtro == "Inquilinos"
                    and u.tipoUsuario != "Inquilino"
                ):
                    continue

            if estado_filtro != "Todos":

                if u.estado.lower() != estado_filtro.lower():
                    continue

            #FILAS
            fila = ctk.CTkFrame(tabla_residentes, fg_color="#F5F5F5", corner_radius=8)
