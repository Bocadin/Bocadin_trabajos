        ctk.CTkButton(ventana_form, text="Guardar", command=guardar).pack(pady=20)

    def activar_usuario():
        nonlocal usuario_seleccionado

        if usuario_seleccionado is None:
            print("Selecciona un usuario")
            return
        abrir_formulario_usuario(usuario_seleccionado)
 
    #Función para botón eliminar usuario
    def eleminar_usuario():
        nonlocal usuario_seleccionado

        if usuario_seleccionado is None:
            print("Selecciona un usuario")
            return

        confirm = messagebox.askyesno(title="Confirmar eliminación", message=f"¿Eliminar al residente {usuario_seleccionado.Username}?")
        if confirm:
            sistema_back.eliminarUsuario(usuario_seleccionado.idUsuario)
            cargar_tabla()

    #BOTONES
    boton_activar = ctk.CTkButton(panel_lateral, text="Activar Residente", fg_color=Color_boton_oscuro, height=35, command=activar_usuario)
    boton_activar.pack(fill="x", padx=20, pady=10)

    boton_reset = ctk.CTkButton(panel_lateral, text="Modificar información", fg_color=Color_boton_oscuro, height=35)
    boton_reset.pack(fill="x", padx=20, pady=5)

    boton_eliminar = ctk.CTkButton(panel_lateral, text="Eliminar Residente", fg_color="#8B0000", hover_color="#5E0000", height=35, command = eleminar_usuario)
