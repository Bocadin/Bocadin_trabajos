            btn_close = ctk.CTkButton(mf, text="✕  Cerrar", fg_color="#24A433", hover_color="#1A7B26", 
                                      height=50, corner_radius=12, font=("Inter", 15, "bold"), 
                                      command=ventana_detalles.destroy)
            btn_close.pack(fill="x", padx=20, pady=20)

    def cargar_tabla():

        for widget in tabla_residentes.winfo_children():

            if widget != header:
                widget.destroy()

        texto_busqueda = entry_busqueda.get().lower()
        tipo_filtro = filtros.get()
        estado_filtro = estado_var.get()

        for u in sistema_back.usuarios.values():

            if u.tipoUsuario == "admin":
                continue

            if texto_busqueda:

                if (
                    texto_busqueda not in u.Username.lower()
                    and texto_busqueda not in str(u.idUsuario)
                ):
                    continue

            if tipo_filtro != "Todos":

                if (
                    tipo_filtro == "Propietarios"
                    and u.tipoUsuario != "Propietario"
                ):
                    continue

                if (
                    tipo_filtro == "Inquilinos"
                    and u.tipoUsuario != "Inquilino"
                ):
                    continue

            if estado_filtro != "Todos":

                if u.estado.lower() != estado_filtro.lower():
                    continue

            #FILAS
            fila = ctk.CTkFrame(tabla_residentes, fg_color="#F5F5F5", corner_radius=8)
            fila.pack(fill="x", pady=2, padx=2)

            id_fila = ctk.CTkLabel(fila, text=u.idUsuario, width=120)
            id_fila.grid (row= 0, column= 0, padx= 10, pady= 10)

            nombre_fila = ctk.CTkLabel(fila, text=u.Username, width=120)
            nombre_fila.grid(row= 0, column = 1, padx = 10)


            tipo_fila = ctk.CTkLabel(fila, text=u.tipoUsuario,width=120)
            tipo_fila.grid (row = 0, column = 2, padx= 10)

            estado_fila = ctk.CTkLabel(fila, text=u.estado, width=120)
            estado_fila.grid (row = 0, column = 3, padx= 10)

            widgets_fila = [fila, id_fila, nombre_fila, tipo_fila, estado_fila]
            
            for widget in widgets_fila:
                widget.bind("<Button-1>",lambda e, user=u, f=fila: seleccionar_usuario(user, f))

            boton_detalles = ctk.CTkButton(fila, text="👁️", width=35, height=35, fg_color=Color_boton_oscuro, command=lambda idU=u.idUsuario: ver_detalles_usuario(str(idU)))
            boton_detalles.grid(row=0, column=4, padx=10)

    cargar_tabla()
    entry_busqueda.bind("<KeyRelease>", lambda e: cargar_tabla())
    filtros.configure(command=lambda _: cargar_tabla())
    estado_var.configure(command=lambda _: cargar_tabla())

    #VENTANA FORMULARIO
    def abrir_formulario_usuario(usuario):
        ventana_form = ctk.CTkToplevel()
        ventana_form.title("Completar Datos")
        ventana_form.geometry("300x300")

        entry_nombre = ctk.CTkEntry(ventana_form, placeholder_text="Nombre completo")
        entry_nombre.pack(pady=10)

        entry_direccion = ctk.CTkEntry(ventana_form, placeholder_text="Dirección")
        entry_direccion.pack(pady=10)

        entry_telefono = ctk.CTkEntry(ventana_form, placeholder_text="Teléfono")
        entry_telefono.pack(pady=10)

        def guardar():
            usuario.nombre_completo = entry_nombre.get()
            usuario.direccion = entry_direccion.get()
            usuario.telefono = entry_telefono.get()
            usuario.estado = "activo"
            sistema_back.guardar_csv_nuevo()
            ventana_form.destroy()

            cargar_tabla()

        ctk.CTkButton(ventana_form, text="Guardar", command=guardar).pack(pady=20)

    def activar_usuario():
        nonlocal usuario_seleccionado

        if usuario_seleccionado is None:
            print("Selecciona un usuario")
            return
        abrir_formulario_usuario(usuario_seleccionado)
 
    #Función para botón eliminar usuario
    def eleminar_usuario():
        nonlocal usuario_seleccionado

        if usuario_seleccionado is None:
            print("Selecciona un usuario")
            return

        confirm = messagebox.askyesno(title="Confirmar eliminación", message=f"¿Eliminar al residente {usuario_seleccionado.Username}?")
        if confirm:
            sistema_back.eliminarUsuario(usuario_seleccionado.idUsuario)
            cargar_tabla()

    #BOTONES
    boton_activar = ctk.CTkButton(panel_lateral, text="Activar Residente", fg_color=Color_boton_oscuro, height=35, command=activar_usuario)
    boton_activar.pack(fill="x", padx=20, pady=10)

    boton_reset = ctk.CTkButton(panel_lateral, text="Modificar información", fg_color=Color_boton_oscuro, height=35)
    boton_reset.pack(fill="x", padx=20, pady=5)

    boton_eliminar = ctk.CTkButton(panel_lateral, text="Eliminar Residente", fg_color="#8B0000", hover_color="#5E0000", height=35, command = eleminar_usuario)
    boton_eliminar.pack(fill="x", padx=20, pady=(5, 20))

