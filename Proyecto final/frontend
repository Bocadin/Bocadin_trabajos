            row_t = ctk.CTkFrame(info_card, fg_color="transparent")
            row_t.pack(fill="x", padx=25, pady=10)
            ctk.CTkLabel(row_t, text="👤", font=("Arial", 18), text_color="#14532D", width=30).pack(side="left")
            ctk.CTkLabel(row_t, text="Tipo:", font=("Inter", 14, "bold"), text_color="#1F2937").pack(side="left", padx=10)
