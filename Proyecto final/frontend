def abrir_panel_usuario(usuario_obj):
# Esta es la ventana que sale cuando logras entrar
    ventana_panel = ctk.CTkToplevel()
    ventana_panel.title(f"Panel de {usuario_obj.nombre}")
    ventana_panel.geometry("700x600")
    ventana_panel.configure(fg_color=Color_fondo)

    ctk.CTkLabel(ventana_panel, text=f"Bienvenido, {usuario_obj.nombre}", font=("Arial", 22, "bold"), text_color=Color_texto_oscuro).pack(pady=20)

    #Frame princiapl
    main_frame = ctk.CTkFrame(ventana_panel, fg_color="transparent")
    main_frame.pack(fill = "both", expand=True, padx=20)

    #Cargar foto de perfil 
    foto_path = getattr(usuario_obj, "foto", None) or getattr(usuario_obj, "foto_perfil", None)
    if foto_path and os.path.exists(foto_path):
        img = ctk.CTkImage(Image.open(foto_path), size=(100, 100))
        lbl = ctk.CTkLabel(main_frame, image=img, text="")
        lbl.image = img
        lbl.pack()
    else:
        ctk.CTkLabel(main_frame, text="👤", font=("Arial", 80)).pack()

    ctk.CTkLabel(main_frame, text=usuario_obj.nombre.upper()).pack()
    ctk.CTkLabel(main_frame, text=usuario_obj.tipoUsuario).pack()

    # Las optiones
    opciones = [
        ("📄 Recibos", lambda: print("Abriendo Recibos")),
        ("💳 Pagos", lambda: print("Abriendo Pagos")),
        ("⚠️ Reportes", lambda: print("Abriendo Reportes"))
    ]

    for texto, comando in opciones:
        btn = ctk.CTkButton(main_frame, text=texto, width=250, height=60, 
                            font=("Arial", 16, "bold"), fg_color=Color_boton_oscuro, 
                            command=comando).pack(fill="x", pady=5)

    #Botones de editar perfil y cerrar sesion
    btn_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    btn_frame.pack(fill="x", pady=15, padx=10)

    ctk.CTkButton(btn_frame, text="EDITAR PERFIL", width=140,
                  fg_color=Color_boton_oscuro,
                  command=lambda: editar_perfil(usuario_obj, ventana_panel)
                  ).pack(side="left", padx=5)
 
    ctk.CTkButton(btn_frame, text="CERRAR SESIÓN", width=140,
                  fg_color="#8B0000",
                  command=ventana_panel.destroy).pack(side="left", padx=5)
    


