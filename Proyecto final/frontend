            ctk.CTkLabel(title_f, text="Información detallada del residente", font=("Inter", 13), text_color="#64748B").pack(anchor="w")

            #Info frame
            info_card = ctk.CTkFrame(mf, fg_color="white", border_color="#E2E8F0", border_width=1, corner_radius=15)
            info_card.pack(fill="both", expand=True, padx=20, pady=10)

            def create_info_row(parent, icon_char, label, value, is_badge=False):
                row = ctk.CTkFrame(parent, fg_color="transparent")
                row.pack(fill="x", padx=25, pady=10)
                
                ctk.CTkLabel(row, text=icon_char, font=("Arial", 18), text_color="#14532D", width=30).pack(side="left")
                ctk.CTkLabel(row, text=label, font=("Inter", 14, "bold"), text_color="#1F2937").pack(side="left", padx=10)
                
                if is_badge:
                    b_color = "#DCFCE7" if value.lower() == "activo" else "#FEE2E2"
                    t_color = "#166534" if value.lower() == "activo" else "#991B1B"
                    badge = ctk.CTkFrame(row, fg_color=b_color, corner_radius=8)
                    badge.pack(side="right")
                    ctk.CTkLabel(badge, text=value.capitalize(), font=("Inter", 13, "bold"), text_color=t_color).pack(padx=12, pady=4)
                else:
                    ctk.CTkLabel(row, text=value, font=("Inter", 14), text_color="#374151").pack(side="right")

            create_info_row(info_card, "👥", "ID Usuario:", str(user.idUsuario))
            create_info_row(info_card, "👤", "Apodo:", user.Username)
            ctk.CTkFrame(info_card, height=1, fg_color="#F1F5F9").pack(fill="x", padx=20, pady=5)
            
