        label_id.configure(text=f"ID: {usuario.idUsuario}")
        label_nombre.configure(text=f"Nombre: {usuario.Username}")

    ventana_detalles = None

    def ver_detalles_usuario(idUsuario):
        nonlocal ventana_detalles

        if (
            ventana_detalles is not None
            and ventana_detalles.winfo_exists()
        ):
            ventana_detalles.destroy()

        if idUsuario in sistema_back.usuarios:

            user = sistema_back.usuarios[idUsuario]

            ventana_detalles = ctk.CTkToplevel()
            ventana_detalles.title(f"Detalles de {user.Username}")
            ventana_detalles.geometry("400x400")
            
            ventana_detalles.lift()
