    scroll_table.pack(fill="both", expand=True)

    def cargar_tabla_consumos(*args):
        for w in scroll_table.winfo_children():
            w.destroy()
        
        filtro = combo_filtro_serv.get()
        mis_consumos = [c for c in sistema_back.consumos.values() if str(c.usuario_id) == str(usuario_obj.idUsuario)]
        
