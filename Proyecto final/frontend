    metodo_seleccionado = ctk.StringVar(value="")

    def crear_opcion_pago(parent, icon_char, title, sub, val, color_base):
        f = ctk.CTkFrame(parent, fg_color="white", corner_radius=12, border_width=2, border_color="#E5E7EB", height=80)
        f.pack(fill="x", padx=20, pady=10)
        f.pack_propagate(False)

        rb = ctk.CTkRadioButton(f, text="", variable=metodo_seleccionado, value=val, width=20)
        rb.place(x=15, rely=0.5, anchor="w")

        # El diseño de la imagen tiene un cuadro de color con el icono
        icon_box = ctk.CTkFrame(f, fg_color=color_base, width=50, height=50, corner_radius=8)
        icon_box.place(x=50, rely=0.5, anchor="w")
        icon_box.pack_propagate(False)
        ctk.CTkLabel(icon_box, text=icon_char, font=("Arial", 24), text_color="white").pack(expand=True)

        txt_f = ctk.CTkFrame(f, fg_color="transparent")
        txt_f.place(x=110, rely=0.5, anchor="w")
        ctk.CTkLabel(txt_f, text=title, font=("Inter", 14, "bold"), text_color="#111827").pack(anchor="w")
        ctk.CTkLabel(txt_f, text=sub, font=("Inter", 11), text_color="gray").pack(anchor="w")

        # Hacer que toda la celda sea clickable
        def on_click(e):
            metodo_seleccionado.set(val)
        
        f.bind("<Button-1>", on_click)
