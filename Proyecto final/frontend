            create_info_row(info_card, "📍", "Dirección:", getattr(user, 'direccion', 'No registrada'))
            create_info_row(info_card, "📞", "Teléfono:", getattr(user, 'telefono', 'No registrado'))
            ctk.CTkFrame(info_card, height=1, fg_color="#F1F5F9").pack(fill="x", padx=20, pady=5)
            
            create_info_row(info_card, "🏠", "Estado:", user.estado, is_badge=True)
            
