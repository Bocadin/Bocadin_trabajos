            s = sistema_back.servicios[servicio_seleccionado.get()]
            ent_n.insert(0, s.nombre); tipo_v.set(s.tipo); ent_t.insert(0, str(s.tarifa))

        ruta_img_seleccionada = ctk.StringVar(value="")
        def seleccionar_foto_servicio():
            archivo = filedialog.askopenfilename(filetypes=[("Imágenes", "*.png *.jpg *.jpeg")])
            if archivo:
                ruta_img_seleccionada.set(archivo)
                lbl_img_path.configure(text=os.path.basename(archivo))

        btn_foto = ctk.CTkButton(form, text="📷 Cargar Icono", fg_color="gray", command=seleccionar_foto_servicio)
        btn_foto.pack(pady=5)
        lbl_img_path = ctk.CTkLabel(form, text="Sin imagen seleccionada", font=("Inter", 10), text_color="gray")
        lbl_img_path.pack()

        def save():
            try:
                nombre = ent_n.get()
                tar = float(ent_t.get())
                if not nombre: return
                
                # Guardar imagen si se seleccionó
                if ruta_img_seleccionada.get():
                    base_dir = os.path.dirname(os.path.abspath(__file__))
                    carpeta_iconos = os.path.join(base_dir, "iconos")
                    os.makedirs(carpeta_iconos, exist_ok=True)
                    destino = os.path.join(carpeta_iconos, f"icono_{nombre.lower()}.png")
                    shutil.copy(ruta_img_seleccionada.get(), destino)

                if es_editar: 
                    sistema_back.editar_servicio(servicio_seleccionado.get(), nombre, tipo_v.get(), tar)
                else: 
                    sistema_back.crear_servicio(nombre, tipo_v.get(), tar)
                
                cargar_servicios()
                cargar_iconos_header()
                form.destroy()
            except Exception as e: 
                mostrar_error(f"Error: {e}")
        
        ctk.CTkButton(form, text="GUARDAR", fg_color=Color_boton_oscuro, command=save).pack(pady=25)


