def abrir_ventana_pagos(usuario_obj):
    ventana_pagos = ctk.CTkToplevel()
    ventana_pagos.title("Centro de Pagos - Simulación")
    ventana_pagos.geometry("1000x700")
    ventana_pagos.configure(fg_color=Color_fondo) 
    ventana_pagos.attributes("-topmost", True)

    
    # Header Frame (Barra superior oscura como en la imagen)
    header_frame = ctk.CTkFrame(ventana_pagos, fg_color="#BCDFC2", height=80, corner_radius=0)
    header_frame.pack(fill="x", side="top")
    header_frame.pack_propagate(False)

    # Info de pago en el header
    pago_info = usuario_obj.obtener_informacion_pago(sistema_back)
    # Simulación de días para el diseño
    dias_vence = "5 DÍAS" if "pendiente" in pago_info["monto"].lower() or pago_info["monto"] != "$0.00" else "0 DÍAS"
    fecha_vence = datetime.now().strftime("%d %b %Y").upper()

    header_content = ctk.CTkFrame(header_frame, fg_color="transparent")
    header_content.pack(expand=True)

    global _img_pago_ref # Referencia global para evitar recolección de basura
    _img_pago_ref = None

    # Label del logo
    lbl_logo_header = ctk.CTkLabel(header_content, text="🏢", font=("Arial", 30))
    lbl_logo_header.pack(side="left", padx=10)

    # Cargar automáticamente el icono desde la carpeta "iconos"
    try:
        base_dir = os.path.dirname(os.path.abspath(__file__))
        ruta_logo = os.path.join(base_dir, "iconos", "icono_pagos.png")

        if os.path.exists(ruta_logo):
            img_edif = Image.open(ruta_logo)
            _img_pago_ref = ctk.CTkImage(img_edif, size=(50, 50))
            lbl_logo_header.configure(image=_img_pago_ref, text="")

    except Exception as e:
        print(f"Error cargando icono del header: {e}")

    lbl_info_pago = ctk.CTkLabel(header_content, 
                                 text=f"SIGUIENTE PAGO: {pago_info['monto']} | VENCE EN {dias_vence} ({fecha_vence})",
                                 font=("Inter", 16, "bold"), text_color=Color_texto_oscuro)
    lbl_info_pago.pack(side="left", padx=20)

    def realizar_pago_click():
        if not metodo_seleccionado.get():
            messagebox.showwarning("Atención", "Seleccione una forma de pago")
            return
            
        serv_ids = [cid for cid, var in servicios_vars.items() if var.get()]
        if not serv_ids:
            messagebox.showwarning("Atención", "No ha seleccionado ningún servicio para pagar")
            return
            
        # Procesar pago de los servicios seleccionados
        for cid in serv_ids:
            sistema_back.marcar_consumo_pagado(cid)
            
        # Verificar si los recibos ahora están totalmente pagados
        # (Si todos los consumos de un recibo están pagados, el recibo se marca como pagado)
        for r in sistema_back.recibos.values():
            if r.estado == "pendiente":
                if all(c.estado == "pagado" for c in r.consumos):
                    r.estado = "pagado"
        
        sistema_back.guardar_recibos_csv()
        sistema_back.guardar_consumos_csv()
        
        messagebox.showinfo("Éxito", f"Se han pagado {len(serv_ids)} servicio(s) correctamente")
        ventana_pagos.destroy()
        abrir_ventana_pagos(usuario_obj)

    btn_pago_ahora = ctk.CTkButton(header_content, text="💸 REALIZAR PAGO AHORA", 
                                   fg_color="#E5E7EB", text_color=Color_texto_oscuro,
                                   font=("Inter", 14, "bold"), height=40,
                                   hover_color="#D1D5DB", command=realizar_pago_click)
    btn_pago_ahora.pack(side="left", padx=10)

    # Botón cerrar
    btn_cerrar = ctk.CTkButton(header_frame, text="✕", fg_color="transparent", text_color=Color_texto_oscuro, 
                               width=40, height=40, font=("Arial", 18, "bold"), 
                               hover_color="#A9C6AE", command=ventana_pagos.destroy)
    btn_cerrar.place(relx=0.97, rely=0.5, anchor="center")

    # Main Scrollable Area
    main_scroll = ctk.CTkScrollableFrame(ventana_pagos, fg_color="transparent")
    main_scroll.pack(fill="both", expand=True, padx=20, pady=20)

    # Mid section split in two
    mid_frame = ctk.CTkFrame(main_scroll, fg_color="transparent")
    mid_frame.pack(fill="x", pady=(0, 20))
    mid_frame.grid_columnconfigure(0, weight=1)
    mid_frame.grid_columnconfigure(1, weight=1)

    # --- LEFT: RESUMEN DETALLADO ---
    resumen_frame = ctk.CTkFrame(mid_frame, fg_color="white", corner_radius=15, border_width=1, border_color="#D1D5DB")
    resumen_frame.grid(row=0, column=0, sticky="nsew", padx=(0, 10))

    ctk.CTkLabel(resumen_frame, text="RESUMEN DETALLADO", font=("Inter", 18, "bold"), text_color="#111827").pack(anchor="w", padx=20, pady=(20, 5))
    
    # Selección individual de servicios
