def abrir_gestion_servicios(admin_obj):
    # Ventana rediseñada según imagen de referencia
    ventana_servicios = ctk.CTkToplevel(ventana_principal)
    ventana_servicios.title("Gestión de Servicios")
    ventana_servicios.geometry("1100x700")
    ventana_servicios.configure(fg_color=Color_fondo)
    ventana_servicios.attributes("-topmost", True)

    # Barra superior para el botón de cerrar
    top_bar = ctk.CTkFrame(ventana_servicios, fg_color="transparent")
    top_bar.pack(fill="x", padx=20, pady=(10, 0))
    
    btn_cerrar_v = ctk.CTkButton(top_bar, text="Cerrar", fg_color="#8B0000", text_color="white", 
                                 width=35, height=35, corner_radius=10, font=("Arial", 16, "bold"),
                                 hover_color="#BE123C", command=ventana_servicios.destroy)
    btn_cerrar_v.pack(side="right")

    main_frame = ctk.CTkFrame(ventana_servicios, fg_color="#C9E2CD", corner_radius=20)
    main_frame.pack(fill="both", expand=True, padx=20, pady=(10, 20))

    # Header con Filtros de Iconos (Unificado)
    header_container = ctk.CTkFrame(main_frame, fg_color="white", corner_radius=15, border_width=1, border_color="#E2E8F0")
    header_container.pack(fill="x", padx=20, pady=(20, 10))

    ctk.CTkLabel(header_container, text="SERVICIOS", font=("Inter", 13, "bold"), text_color="#1E293B").pack(pady=(10, 0))
    
    icons_row = ctk.CTkFrame(header_container, fg_color="transparent")
    icons_row.pack(pady=10)

    filtro_servicio_actual = ctk.StringVar(value="Todos")
    
    def set_filtro_serv(n):
        filtro_servicio_actual.set(n)
        cargar_servicios()

    def cargar_iconos_header():
        for w in icons_row.winfo_children(): w.destroy()
        
        # Siempre incluir "Todos"
        btn_f_all = ctk.CTkFrame(icons_row, fg_color="transparent")
        btn_f_all.pack(side="left", padx=8)
        
        img_todos = cargar_icono("icono_todos.png")
        if img_todos:
            btn = ctk.CTkButton(btn_f_all, image=img_todos, text="", width=45, height=45, 
                                 fg_color="#F8FAFC", hover_color="#E2E8F0", corner_radius=10,
                                 command=lambda: set_filtro_serv("Todos"))
        else:
            btn = ctk.CTkButton(btn_f_all, text="📄", font=("Arial", 20), width=45, height=45, 
                                 fg_color="#F8FAFC", hover_color="#E2E8F0", corner_radius=10,
                                 command=lambda: set_filtro_serv("Todos"))
        btn.pack()
        ctk.CTkLabel(btn_f_all, text="Todos", font=("Inter", 9), text_color="gray").pack()

        # Cargar iconos de servicios existentes
        servicios_nombres = sorted(list(set([s.nombre for s in sistema_back.servicios.values()])))
        for nombre in servicios_nombres:
            btn_f = ctk.CTkFrame(icons_row, fg_color="transparent")
            btn_f.pack(side="left", padx=8)
            
            icon_file = f"icono_{nombre.lower()}.png"
            img_ctk = cargar_icono(icon_file)
            
            if img_ctk:
                btn = ctk.CTkButton(btn_f, image=img_ctk, text="", width=45, height=45, 
                                     fg_color="#F8FAFC", hover_color="#E2E8F0", corner_radius=10,
                                     command=lambda n=nombre: set_filtro_serv(n))
            else:
                # Emojis predeterminados si no hay imagen
                emojis = {"Agua": "💧", "Luz": "💡", "Gas": "🔥", "Seguridad": "🛡️", "Mantenimiento": "🛠️"}
                emoji = emojis.get(nombre, "📄")
                btn = ctk.CTkButton(btn_f, text=emoji, font=("Arial", 20), width=45, height=45, 
                                     fg_color="#F8FAFC", hover_color="#E2E8F0", corner_radius=10,
                                     command=lambda n=nombre: set_filtro_serv(n))
            btn.pack()
            ctk.CTkLabel(btn_f, text=nombre, font=("Inter", 9), text_color="gray").pack()

    cargar_iconos_header()

    # Barra de Filtros de Estado y Búsqueda
    controls_bar = ctk.CTkFrame(main_frame, fg_color="transparent")
    controls_bar.pack(fill="x", padx=20, pady=10)
    
    filtro_estado = ctk.StringVar(value="Ver Todo")
    for st in ["Ver Todo", "Medido", "Cuota Fija"]:
        btn = ctk.CTkButton(controls_bar, text=st, width=90, height=30, corner_radius=10,
                             fg_color="#F8FAFC", text_color="#64748B", border_width=1, border_color="#E2E8F0",
                             hover_color="#F1F5F9", command=lambda s=st: [filtro_estado.set(s), cargar_servicios()])
        btn.pack(side="left", padx=5)

    btn_reset = ctk.CTkButton(controls_bar, text="Borrar Filtros", width=100, height=30, fg_color="transparent", 
                               text_color="#8B0000", hover_color="#FEF2F2", command=lambda: [filtro_servicio_actual.set("Todos"), filtro_estado.set("Ver Todo"), cargar_servicios()])
    btn_reset.pack(side="right", padx=5)

    # Cuerpo Principal
    body_container = ctk.CTkFrame(main_frame, fg_color="transparent")
    body_container.pack(fill="both", expand=True, padx=20, pady=10)

    # Grid Izquierdo
    grid_scroll = ctk.CTkScrollableFrame(body_container, fg_color="transparent")
    grid_scroll.pack(side="left", fill="both", expand=True, padx=(0, 15))

    # Sidebar Derecho
    sidebar = ctk.CTkFrame(body_container, fg_color="transparent", width=280)
    sidebar.pack(side="right", fill="y")
    sidebar.pack_propagate(False)

    # Botones Admin
    ctk.CTkButton(sidebar, text="+ AGREGAR NUEVO SERVICIO", fg_color="#1E293B", height=45, corner_radius=10, font=("Inter", 12, "bold"), command=lambda: abrir_form_servicio(False)).pack(fill="x", pady=5)

    # Sección Movimientos
    mov_box = ctk.CTkFrame(sidebar, fg_color="#F8FAFC", corner_radius=15, border_width=1, border_color="#E2E8F0")
    mov_box.pack(fill="both", expand=True, pady=20)
    ctk.CTkLabel(mov_box, text="ÚLTIMOS MOVIMIENTOS", font=("Inter", 11, "bold"), text_color="#475569").pack(pady=10)

    scroll_mov = ctk.CTkScrollableFrame(mov_box, fg_color="transparent")
    scroll_mov.pack(fill="both", expand=True, padx=5, pady=5)

    def cargar_movimientos():
        for w in scroll_mov.winfo_children(): w.destroy()
        for c in reversed(list(sistema_back.consumos.values())[-10:]):
            s_nom = sistema_back.servicios[c.servicio_id].nombre if c.servicio_id in sistema_back.servicios else "Srv"
            txt = f"{'✅' if c.estado=='pagado' else '⏳'} {s_nom}: ${c.total(sistema_back):.1f}"
            ctk.CTkLabel(scroll_mov, text=txt, font=("Inter", 11), text_color="#64748B", anchor="w").pack(pady=2, fill="x")

    cargar_movimientos()

    servicio_seleccionado = ctk.StringVar(value="")

    def cargar_servicios():
        for w in grid_scroll.winfo_children(): w.destroy()
        f_s = filtro_servicio_actual.get()
        f_e = filtro_estado.get()
        
        col, row = 0, 0
        grid_scroll.grid_columnconfigure((0, 1), weight=1)

        for s_id, s in sistema_back.servicios.items():
            if f_s != "Todos" and f_s.lower() not in s.nombre.lower(): continue
            if f_e == "Medido" and s.tipo != "medido": continue
            if f_e == "Cuota Fija" and s.tipo != "fijo": continue

            card = ctk.CTkFrame(grid_scroll, fg_color="white", corner_radius=15, border_width=1, border_color="#F1F5F9")
            card.grid(row=row, column=col, padx=10, pady=10, sticky="nsew")

            # Header Card
            card_head = ctk.CTkFrame(card, fg_color="transparent")
            card_head.pack(fill="x", padx=15, pady=15)
            
            icon_img = cargar_icono(f"icono_{s.nombre.lower()}.png")
            if icon_img: ctk.CTkLabel(card_head, image=icon_img, text="").pack(side="left")
            else: ctk.CTkLabel(card_head, text="📄", font=("Arial", 20)).pack(side="left")

            info_f = ctk.CTkFrame(card_head, fg_color="transparent")
            info_f.pack(side="left", padx=10)
            ctk.CTkLabel(info_f, text=s.nombre.upper(), font=("Inter", 14, "bold"), text_color="#1E293B").pack(anchor="w")
            ctk.CTkLabel(info_f, text=f"Tipo: {s.tipo}", font=("Inter", 10), text_color="#94A3B8").pack(anchor="w")

            badge = ctk.CTkFrame(card, fg_color="#DCFCE7", corner_radius=8)
            badge.pack(anchor="w", padx=15)
            ctk.CTkLabel(badge, text="Activo", font=("Inter", 10, "bold"), text_color="#166534").pack(padx=8, pady=2)

            ctk.CTkLabel(card, text=f"${s.tarifa:.2f} / {('u' if s.tipo=='medido' else 'mes')}", font=("Inter", 22, "bold"), text_color="#0F172A").pack(anchor="w", padx=15, pady=10)

            btns = ctk.CTkFrame(card, fg_color="transparent")
            btns.pack(fill="x", padx=15, pady=(0, 15))
            
            ctk.CTkButton(btns, text="Editar", width=70, height=30, fg_color="#F1F5F9", text_color="#475569", command=lambda i=s_id: [servicio_seleccionado.set(i), abrir_form_servicio(True)]).pack(side="left", padx=2, expand=True, fill="x")
            
            ctk.CTkButton(btns, text="Cuentas", width=80, height=30, fg_color="#1E293B", font=("Inter", 10, "bold"),
                           command=lambda i=s_id: abrir_cuentas_servicio(i)).pack(side="left", padx=2, expand=True, fill="x")
            
            ctk.CTkButton(btns, text="🗑️", width=30, height=30, fg_color="#FEF2F2", text_color="#8B0000", hover_color="#FEE2E2", command=lambda i=s_id: [servicio_seleccionado.set(i), eliminar_servicio_ui()]).pack(side="left", padx=2)

            col += 1
            if col > 1: col, row = 0, row + 1

    def eliminar_servicio_ui():
        if servicio_seleccionado.get() and messagebox.askyesno("Confirmar", "¿Eliminar servicio?"):
            sistema_back.eliminar_servicio(servicio_seleccionado.get())
            cargar_servicios()

    def abrir_cuentas_servicio(s_id):
        s_obj = sistema_back.servicios.get(s_id)
        if not s_obj: return
        
        ventana_cuentas = ctk.CTkToplevel(ventana_servicios)
        ventana_cuentas.title(f"Cuentas: {s_obj.nombre}")
        ventana_cuentas.geometry("450x600")
        ventana_cuentas.configure(fg_color="#C9E2CD")
        ventana_cuentas.attributes("-topmost", True)
        
        main_f = ctk.CTkFrame(ventana_cuentas, fg_color="white", corner_radius=15)
        main_f.pack(fill="both", expand=True, padx=20, pady=20)
        
        ctk.CTkLabel(main_f, text=f"DEUDORES - {s_obj.nombre.upper()}", font=("Inter", 16, "bold"), text_color="#1E293B").pack(pady=15)
        
