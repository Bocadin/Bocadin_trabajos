def abrir_olvido_pass():
    ventana_olvido = ctk.CTkToplevel()
    ventana_olvido.geometry("400x400")
    ventana_olvido.title("Recuperar Cuenta")
    ventana_olvido.configure(fg_color=Color_fondo)
    ventana_olvido.attributes("-topmost", True)

# Encabezado visual
    ctk.CTkLabel(
        ventana_olvido, 
        text="Restablecer Contraseña", 
        font=("Arial", 20, "bold"),
        text_color=Color_texto_oscuro
    ).pack(pady=20)
    
# Campo para identificar al usuario
    ent_u = ctk.CTkEntry(
        ventana_olvido, 
        placeholder_text="Nombre de usuario registrado", 
        width=280,
        height=35,
        corner_radius=10
    )
    ent_u.pack(pady=10)
    
# Campo para la nueva clave
    ent_p_nueva = ctk.CTkEntry(
        ventana_olvido, 
        placeholder_text="Nueva Contraseña", 
        show="*", 
        width=280,
        height=35,
        corner_radius=10
    )
    ent_p_nueva.pack(pady=10)

# Nueva logica de conexcion con el back
    def ejecutar_actualizacion():
        nombre_usuario = ent_u.get().strip()
        nueva_clave    = ent_p_nueva.get().strip()

# Validacion 1: Campos obligatorios
        if not nombre_usuario or not nueva_clave:
            print("Error: Todos los campos deben ser completados para continuar.")
            return

# Llamada al backend para actualizar la contraseña
        resultado_exito = sistema_back.actualizarContraseña(nombre_usuario, nueva_clave)

        if resultado_exito:
# Si el backend devolvio True, el CSV ya se guardo :D
            print(f"Sincronización exitosa para el usuario: {nombre_usuario}")
            mostrar_mensaje_actualizado(ventana_olvido)
        else:
# Si el backend devolvió False (el usuario no existe)
            mostrar_error("El usuario no existe en la base de datos.")

# Boton principal de accion
    btn_confirmar = ctk.CTkButton(
        ventana_olvido, 
        text="Guardar Nueva Contraseña", 
        fg_color=Color_boton_oscuro,
        hover_color="#004D40",
        width=220,
        height=45,
        corner_radius=15,
        font=("Arial", 13, "bold"),
        command=ejecutar_actualizacion 
    )
    btn_confirmar.pack(pady=30)

# Boton para cancelar
    ctk.CTkButton(
        ventana_olvido, 
        text="Cancelar", 
        fg_color="transparent", 
        text_color="red",
        command=ventana_olvido.destroy
    ).pack()

def abrir_login_usuario():
# Ventana de login que conecta con el backend
    ventana_menu.withdraw()

    ventana_login = ctk.CTkToplevel(ventana_principal)
    ventana_login.title("Inicio de Sesión")
    ventana_login.geometry("400x450")
    ventana_login.configure(fg_color=Color_fondo)
    ventana_login.attributes("-topmost", True)

    main_frame = ctk.CTkFrame(ventana_login, fg_color="#BCDFC2", corner_radius= 20, border_width=0)
    main_frame.place(relx=0.5, rely=0.5, anchor=tk.CENTER, relwidth=0.8, relheight=0.8)

    ctk.CTkLabel(main_frame, text="🔑 Ingreso Usuario", font=("Arial", 24, "bold"), text_color="#162440").pack(pady=20)
    
    ent_user = ctk.CTkEntry(main_frame, placeholder_text="Nombre de Usuario", width=250, height= 35, border_width=2, corner_radius=10)
    ent_user.pack(pady=10)

    ent_pass = ctk.CTkEntry(main_frame, placeholder_text="Contraseña", show="*", width=250, height= 35, border_width=2, corner_radius=10)
    ent_pass.pack(pady=10)

    def intentar_login():
        u = ent_user.get()
        p = ent_pass.get()
        usuario = sistema_back.autenticar(u, p)
        
        if usuario:
            ventana_login.destroy()
            abrir_panel_usuario(usuario) 
        else:
            print("Error: Usuario o contraseña incorrectos")

    ctk.CTkButton(main_frame, text="Entrar", fg_color=Color_boton_oscuro, command=intentar_login).pack(pady=15)
    ctk.CTkButton(main_frame, text="Olvidé mi contraseña", fg_color="transparent", text_color="blue", hover=False, command=abrir_olvido_pass).pack()
    ctk.CTkButton(main_frame, text="Volver", command=lambda: [ventana_login.destroy(), ventana_menu.deiconify()]).pack(pady=10)

