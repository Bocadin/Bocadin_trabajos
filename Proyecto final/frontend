class PanelUsuario:
    # Encapsula el Panel de Control del Residente de forma limpia, robusta y modular.
    # Permite refrescar la información en pantalla en tiempo real tras la edición de perfil.
    
    def __init__(self, usuario_obj):
        self.usuario_obj = usuario_obj
        self.ventana_panel = ctk.CTkToplevel()
        self.ventana_panel.title("Panel de Control - Sistema SAC")
        self.ventana_panel.geometry("950x650")
        self.ventana_panel.configure(fg_color=Color_fondo)
        
        # Vincular cierre de ventana (botón X) al método de cerrar sesión seguro
        self.ventana_panel.protocol("WM_DELETE_WINDOW", self.logout)
        
        # Fuentes tipográficas predefinidas para homogeneidad
        self.font_title = ("Inter", 28, "bold")
        self.font_subtitle = ("Inter", 16, "bold")
        self.font_card_title = ("Inter", 12, "bold")
        self.font_card_value = ("Inter", 24, "bold")
        self.font_sidebar = ("Inter", 13)
        
        # Inicializa y dibuja los componentes del panel
        self.crear_componentes()

    def logout(self):
        # Asegurar deiconify y focus antes de destruir la ventana del panel
        ventana_menu.deiconify()
        ventana_menu.focus_force()
        self.ventana_panel.destroy()

    def crear_componentes(self):
        # Construcción de la barra lateral izquierda (Sidebar)
        self.sidebar = ctk.CTkFrame(self.ventana_panel, fg_color="#C9E2CD", width=250, corner_radius=0)
        self.sidebar.pack(side="left", fill="y")
        self.sidebar.pack_propagate(False)

        # Contenedor dinámico de información (foto, nombre y estado)
        self.user_frame = ctk.CTkFrame(self.sidebar, fg_color="transparent")
        self.user_frame.pack(pady=40, padx=20, fill="x")

        # Contenedor para botones de navegación
        self.nav_frame = ctk.CTkFrame(self.sidebar, fg_color="transparent")
        self.nav_frame.pack(fill="both", expand=True, padx=10)

        # Configuración de botones e interacciones
        botones_nav = [
            ("👤 Editar Perfil", "Editar Perfil"),
            ("📄 Mis Recibos", "Recibos"),
            ("💳 Realizar Pagos", "Pagos"),
            ("⚠️ Reportes", "Reportes")
        ]

        for icono_texto, cmd_name in botones_nav:
            btn = ctk.CTkButton(self.nav_frame, text=icono_texto, anchor="w", fg_color=Color_boton_oscuro, 
                                text_color="White", hover_color="#1B1F28", height=45,
                                font=self.font_sidebar, command=lambda c=cmd_name: self.on_nav_click(c))
            btn.pack(fill="x", pady=5)

        # Botón para salir y cerrar sesión
        logout_btn = ctk.CTkButton(self.sidebar, text="Cerrar Sesión", fg_color="#8B0000", text_color="#FFFFFF",
                                   hover_color="#520505", height=40, font=("Inter", 13, "bold"),
                                   command=self.logout)
        logout_btn.pack(side="bottom", fill="x", padx=20, pady=20)

        # Contenedor dinámico para el área de contenido a la derecha
        self.content = ctk.CTkFrame(self.ventana_panel, fg_color="transparent")
        self.content.pack(side="right", fill="both", expand=True, padx=40, pady=40)

        # Primera carga de datos visuales en pantalla
        self.cargar_datos_dinamicos()

    def on_nav_click(self, opcion):
        # Evento disparado al interactuar con el menú de navegación lateral.
        # Oculta temporalmente la ventana principal antes de desplegar la subventana.
        self.ventana_panel.withdraw()
        if opcion == "Editar Perfil":
            # Pasa el callback self.refrescar al editor de perfil para lograr una actualización instantánea
            editar_perfil(self.usuario_obj, self.ventana_panel, self.refrescar)
        elif opcion == "Recibos":
            abrir_mis_recibos(self.usuario_obj, self.ventana_panel)
        elif opcion == "Pagos":
            abrir_ventana_pagos(self.usuario_obj, self.ventana_panel)
        elif opcion == "Reportes":
            abrir_reportes_usuario(self.usuario_obj, self.ventana_panel)

    def cargar_datos_dinamicos(self):
        # Limpia de forma segura los widgets dinámicos existentes para evitar solapamientos
        for w in self.user_frame.winfo_children():
            w.destroy()
        for w in self.content.winfo_children():
            w.destroy()

        # Carga dinámica de la foto de perfil en el sidebar
        foto_path = getattr(self.usuario_obj, "foto_perfil", None)
        try:
            if foto_path and os.path.exists(foto_path):
                img_pil = Image.open(foto_path)
                img = ctk.CTkImage(img_pil, size=(150, 150))
                lbl_foto = ctk.CTkLabel(self.user_frame, image=img, text="")
                lbl_foto.pack(pady=10)
            else:
                raise FileNotFoundError
        except:
            ctk.CTkLabel(self.user_frame, text="👤", font=("Arial", 60)).pack(pady=10)

        # Nombre de usuario actual
        ctk.CTkLabel(self.user_frame, text=self.usuario_obj.Username, font=("Inter", 20, "bold"), text_color=Color_boton_oscuro).pack()
        
        # Estado activo del residente
        status_frame = ctk.CTkFrame(self.user_frame, fg_color="transparent")
        status_frame.pack(pady=5)
        ctk.CTkLabel(status_frame, text="●", text_color="#10B981", font=("Arial", 12)).pack(side="left")
        ctk.CTkLabel(status_frame, text=" Propietario Activo", font=("Inter", 12), text_color="#10B981").pack(side="left")

        # --- ÁREA DE CONTENIDO PRINCIPAL ---
        # Mensaje de bienvenida personalizado
        ctk.CTkLabel(self.content, text=f"Bienvenido, {self.usuario_obj.Username}", font=self.font_title, text_color=Color_boton_oscuro).pack(anchor="w", pady=(0, 30))

        # Tarjeta informativa del próximo pago y vencimiento
        pago_info = self.usuario_obj.obtener_informacion_pago(sistema_back)
        
        user_pago = ctk.CTkFrame(self.content, fg_color="white", corner_radius=15)
        user_pago.pack(fill="x", pady=(0, 20))
        
        user_pago.columnconfigure(0, weight=1)
        user_pago.columnconfigure(1, weight=0)

        txt_frame = ctk.CTkFrame(user_pago, fg_color="transparent")
        txt_frame.grid(row=0, column=0, padx=30, pady=25, sticky="w")
        
        ctk.CTkLabel(txt_frame, text="PRÓXIMO VENCIMIENTO", font=self.font_card_title, text_color="gray").pack(anchor="w")
        ctk.CTkLabel(txt_frame, text=pago_info["fecha"], font=self.font_card_value, text_color=Color_boton_oscuro).pack(anchor="w")

        monto_info = ctk.CTkLabel(user_pago, text=pago_info["monto"], font=("Inter", 32, "bold"), text_color="#16A34A")
        monto_info.grid(row=0, column=1, padx=40, pady=25, sticky="e")

        # Contenedor de detalles del perfil
        user_frame_info = ctk.CTkFrame(self.content, fg_color="white", corner_radius=15)
        user_frame_info.pack(fill="both", expand=True)

        ctk.CTkLabel(user_frame_info, text="Información del Residente", font=self.font_subtitle, text_color=Color_boton_oscuro).pack(anchor="w", padx=30, pady=(25, 15))

        details_frame = ctk.CTkFrame(user_frame_info, fg_color="transparent")
        details_frame.pack(fill="x", padx=30)

        def add_detail(label, value):
            row = ctk.CTkFrame(details_frame, fg_color="transparent")
            row.pack(fill="x", pady=8)
            ctk.CTkLabel(row, text=label, font=("Inter", 13), text_color="gray", width=120, anchor="w").pack(side="left")
            ctk.CTkLabel(row, text=value, font=("Inter", 13, "bold"), text_color=Color_boton_oscuro).pack(side="left")

        # Rellena los datos dinámicos obtenidos desde el backend del usuario
        datos = self.usuario_obj.consultar_perfil()
        add_detail("ID de Usuario:", datos["idUsuario"])
        add_detail("Nombre Completo:", datos["nombre_completo"])
        add_detail("Dirección:", datos["direccion"])
        add_detail("Teléfono:", datos["telefono"])
        
        correo = getattr(self.usuario_obj, "correo", "No registrado")
        add_detail("Correo:", correo)

    def refrescar(self):
        # Método público invocado como callback para refrescar la interfaz visual
        # y forzar el redibujado de la información tras haber modificado el perfil.
        self.cargar_datos_dinamicos()


# Mantiene la compatibilidad con el resto del código llamando a la nueva clase PanelUsuario
def abrir_panel_usuario(usuario_obj):
    PanelUsuario(usuario_obj)

