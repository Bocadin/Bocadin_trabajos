                cb = ctk.CTkCheckBox(row, text="", variable=var, width=20, command=on_service_toggle, fg_color="#1E293B")
                cb.pack(side="left", padx=10)
                
                # Icono
                icon_f = f"icono_{nom.lower()}.png"
                img_ctk = cargar_icono(icon_f)
                if img_ctk:
                    ctk.CTkLabel(row, image=img_ctk, text="").pack(side="left", padx=5)
                else:
                    emojis = {"Agua": "💧", "Luz": "💡", "Gas": "🔥", "Seguridad": "🛡️", "Mantenimiento": "🛠️"}
                    ctk.CTkLabel(row, text=emojis.get(nom, "📄"), font=("Arial", 16)).pack(side="left", padx=5)
                
                ctk.CTkLabel(row, text=nom, font=("Inter", 13, "bold"), text_color="#1E293B").pack(side="left", padx=5)
                ctk.CTkLabel(row, text=f"${monto:.2f}", font=("Inter", 13, "bold"), text_color="#111827").pack(side="right", padx=15)

    actualizar_total_pago()

    # --- RIGHT: MÉTODOS DE PAGO ---
