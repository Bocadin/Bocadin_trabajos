        "Septiembre": "septiembre", "Octubre": "octubre", "Noviembre": "noviembre", "Diciembre": "diciembre"
    }

    filas = []

    def seleccionar_recibo(rec, fila):
        for f in filas:
            f.configure(border_color="#D1D5DB", border_width=1)
        fila.configure(border_color="#1B4332", border_width=2)
        
        txt_preview.configure(state="normal")
        txt_preview.delete("1.0", "end")
        
        serv_names = []
        for c in rec.consumos:
            s_obj = sistema_back.servicios.get(c.servicio_id)
            if s_obj: serv_names.append(s_obj.nombre)
        main_serv = ", ".join(list(set(serv_names))) if serv_names else "Varios"

        content = f"\n"
        content += f"      {'CONDOMINIO SAC':^40}\n"
        content += f"      {'='*30}\n\n"
        content += f"      Número del Recibo: {rec.idRecibo}\n"
        content += f"      Fecha: {rec.periodo}\n"
        content += f"      Servicio: {main_serv}\n"
        content += f"      Usuario: {usuario_obj.nombre_completo}\n\n"
        content += f"      {'Servicio':<20} {'Total':>10}\n"
        content += f"      {'-'*31}\n"
        
        for c in rec.consumos:
            serv = sistema_back.servicios.get(c.servicio_id)
            nom = serv.nombre if serv else c.servicio_id
            monto = c.total(sistema_back)
            content += f"      {nom[:18]:<20} ${monto:>10.2f}\n"
            
        content += f"      {'-'*31}\n"
        content += f"      {'TOTAL:':<20} ${rec.total_pagar:>10.2f}\n\n"
        content += f"      Estado del Pago: {rec.estado.upper()}\n"
        content += f"      {'-'*31}\n"
        content += f"      {'Gracias por su pago':^31}\n"
        
        txt_preview.insert("1.0", content)
        txt_preview.configure(state="disabled")

    def cargar_recibos(*args):
        for w in scroll_recibos.winfo_children():
            w.destroy()
        filas.clear()
        
        sel_mes = meses_map.get(combo_mes.get(), "Todos")
        sel_anio = combo_anio.get()
        sel_stat = filter_status.get()
        
        mis_recs = [r for r in sistema_back.recibos.values() if str(getattr(r.usuario, 'idUsuario', r.usuario)) == str(usuario_obj.idUsuario)]
        
        for r in mis_recs:
            if sel_mes != "Todos" and sel_mes.lower() not in r.periodo.lower(): continue
            if sel_anio != "Todos" and sel_anio not in r.periodo: continue
            if sel_stat != "Todos" and r.estado != sel_stat: continue
            
            main_serv_name = "Servicios Varios"
            icon = "📄"
            if r.consumos:
                serv = sistema_back.servicios.get(r.consumos[0].servicio_id)
                if serv:
                    main_serv_name = serv.nombre
                    icon = icons_map.get(serv.nombre, "📄")

            f = ctk.CTkFrame(scroll_recibos, fg_color="white", corner_radius=12, border_width=1, border_color="#D1D5DB", height=80)
            f.pack(fill="x", pady=5)
            f.pack_propagate(False)
            
            ctk.CTkLabel(f, text=icon, font=("Arial", 24)).place(x=20, rely=0.5, anchor="w")
            ctk.CTkLabel(f, text=f"{main_serv_name} - {r.periodo}", font=("Inter", 14, "bold"), text_color="#111827").place(x=60, y=15)
            
            badge_color = "#D1FAE5" if r.estado == "pagado" else "#FEE2E2"
            text_color = "#065F46" if r.estado == "pagado" else "#991B1B"
            badge = ctk.CTkFrame(f, fg_color=badge_color, corner_radius=8)
            badge.place(x=60, y=45)
            ctk.CTkLabel(badge, text=r.estado.capitalize(), font=("Inter", 11, "bold"), text_color=text_color).pack(padx=8, pady=2)
            
            ctk.CTkLabel(f, text=f"${r.total_pagar:.2f}", font=("Inter", 18, "bold"), text_color="#111827").place(relx=0.95, rely=0.5, anchor="e")
            
            f.bind("<Button-1>", lambda e, r=r, f=f: seleccionar_recibo(r, f))
            for child in f.winfo_children():
                child.bind("<Button-1>", lambda e, r=r, f=f: seleccionar_recibo(r, f))
                if isinstance(child, ctk.CTkFrame):
                    for gc in child.winfo_children():
                        gc.bind("<Button-1>", lambda e, r=r, f=f: seleccionar_recibo(r, f))
            
            filas.append(f)

    combo_mes.configure(command=cargar_recibos)
    combo_anio.configure(command=cargar_recibos)
    cargar_recibos()

