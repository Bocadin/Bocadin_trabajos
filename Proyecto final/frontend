            child.bind("<Button-1>", on_click)

    crear_opcion_pago(metodos_frame, "💳", "Tarjeta Bancaria (Visa/MC)", "Rápido y Seguro", "tarjeta", "#1A365D")
    crear_opcion_pago(metodos_frame, "🏦", "Transferencia Bancaria", "Detalles de Cuenta", "transfer", "#2D5A27")
    crear_opcion_pago(metodos_frame, "🌐", "Pago en Línea", "Portal Seguro", "online", "#1E3A8A")

    # --- BOTTOM: HISTORIAL DE CONSUMOS ---
    historial_frame = ctk.CTkFrame(main_scroll, fg_color="white", corner_radius=15, border_width=1, border_color="#D1D5DB")
    historial_frame.pack(fill="both", expand=True, pady=10)

    header_historial = ctk.CTkFrame(historial_frame, fg_color="transparent")
    header_historial.pack(fill="x", padx=20, pady=15)

    ctk.CTkLabel(header_historial, text="HISTORIAL DE CONSUMOS", font=("Inter", 18, "bold"), text_color="#111827").pack(side="left")
    
    # Filtro por servicio
    servicios_unicos = ["Todos"] + [s.nombre for s in sistema_back.servicios.values()]
    combo_filtro_serv = ctk.CTkComboBox(header_historial, values=servicios_unicos, width=180)
    combo_filtro_serv.set("Todos")
    combo_filtro_serv.pack(side="right", padx=10)
