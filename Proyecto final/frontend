    ventana_login.attributes("-topmost", True)

    main_frame = ctk.CTkFrame(ventana_login, fg_color="#BCDFC2", corner_radius=20, border_width=0)
    main_frame.place(relx=0.5, rely=0.5, anchor=tk.CENTER, relwidth=0.8, relheight=0.8 )

    icon_reg = cargar_icono("icono_login.png")
    if icon_reg:
        icon_reg.configure(size=(60, 60))# Tamaño bastante visible
        ctk.CTkLabel(main_frame, image=icon_reg, text="").pack(pady=(25, 5))
    else:
        ctk.CTkLabel(main_frame, text="🔑", font=("Inter", 60)).pack(pady=20)
    
