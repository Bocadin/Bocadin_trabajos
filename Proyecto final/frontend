    ventana_reg.configure(fg_color=Color_fondo)
    ventana_reg.attributes("-topmost", True)

    main_frame = ctk.CTkFrame(ventana_reg, fg_color="white", corner_radius=15)
    main_frame.pack(fill="both", expand=True, padx=30, pady=30)

    ctk.CTkLabel(main_frame, text="Registro de Consumo", font=("Arial", 18, "bold"), text_color=Color_texto_oscuro).pack(pady=10)
    
    # Menú desplegable para seleccionar a qué residente cobrarle
    residentes = [f"{u.idUsuario} - {u.Username}" for u in sistema_back.usuarios.values() if u.tipoUsuario != "admin"]
    combo_residente = ctk.CTkComboBox(main_frame, values=residentes if residentes else ["Sin residentes"], width=300)
    combo_residente.set("Lista Residente")
    combo_residente.pack(pady=10)

    ctk.CTkLabel(main_frame, text="Servicio:", font=("Arial", 14, "bold"), anchor="w", text_color="black").pack(fill="x", padx=40, pady=(10, 0))

    servicios_frame = ctk.CTkFrame(main_frame, fg_color="transparent")
    servicios_frame.pack(pady=10)

    servicio_var = ctk.StringVar(value="")

    colores = ["#A9C2F0", "#FFF4B0", "#D3C2A3", "#FFC1C1"]
    idx = 0
    todos_servicios = list(sistema_back.servicios.values())

    ent_anterior = ctk.CTkEntry(main_frame, placeholder_text="Lectura anterior", width=300)
    ent_anterior.pack(pady=5)

    ent_actual = ctk.CTkEntry(main_frame, placeholder_text="Lectura Actual", width=300)
    ent_actual.pack(pady=5)

    lbl_consumo = ctk.CTkLabel(main_frame, text="Consumo: 0", font=("Arial", 14, "bold"),
                               text_color="white", fg_color="#89cd84", width=300, corner_radius=5)
    lbl_consumo.pack(pady=5)

    def calcular_consumo(*args):
        try:
            ant = float(ent_anterior.get())
            act = float(ent_actual.get())
            cons = act - ant
            lbl_consumo.configure(text=f"Consumo: {cons}")
        except:
            lbl_consumo.configure(text="Consumo: 0")

    def on_servicio_select():
        # Si el servicio es de cuota fija, esconde las cajas de lectura y muestra el total directo
        s_id = servicio_var.get()
        if s_id in sistema_back.servicios:
            s = sistema_back.servicios[s_id]
            if s.tipo == "fijo":
                ent_anterior.pack_forget()
                ent_actual.pack_forget()
                lbl_consumo.configure(text=f"Cuota Fija: ${s.tarifa}")
            else:
                ent_anterior.pack(pady=5, before=lbl_consumo)
                ent_actual.pack(pady=5, before=lbl_consumo)
                calcular_consumo()

    for s in todos_servicios:
        btn_color = colores[idx % len(colores)]
        idx += 1
        btn = ctk.CTkRadioButton(servicios_frame, text=s.nombre, variable=servicio_var, value=s.idServicio,
                                 fg_color=Color_boton_oscuro, font=("Arial", 14, "bold"), text_color="black",
                                 command=on_servicio_select)
        btn.pack(side="left", padx=10)

    if not todos_servicios:
        ctk.CTkLabel(servicios_frame, text="No hay servicios creados.", text_color="black").pack()

    ent_anterior.bind("<KeyRelease>", calcular_consumo)
    ent_actual.bind("<KeyRelease>", calcular_consumo)

    from datetime import datetime
    ent_fecha = ctk.CTkEntry(main_frame, placeholder_text="Fecha (YYYY-MM-DD)", width=300)
    ent_fecha.insert(0, datetime.now().strftime("%Y-%m-%d"))
    ent_fecha.pack(pady=5)

    def guardar_consumo():
        try:
            res_id = combo_residente.get().split(" - ")[0]
            serv_id = servicio_var.get()

            s = sistema_back.servicios.get(serv_id)
            if not s:
                mostrar_error("Seleccione un servicio válido.")
                return

            if s.tipo == "fijo":
                cons = 1.0 # Cantidad 1 para que al multiplicar por tarifa de el total
            else:
                ant = float(ent_anterior.get())
                act = float(ent_actual.get())
                cons = act - ant

            fecha = ent_fecha.get()

            if serv_id and res_id and res_id not in ("Sin residentes", "Lista Residente"):
                sistema_back.registrar_consumo(cons, res_id, serv_id, fecha)
                ventana_reg.destroy()
            else:
                mostrar_error("Seleccione residente y servicio.")
        except Exception as e:
            mostrar_error("Verifique los datos ingresados.")

    ctk.CTkButton(main_frame, text="Guardar", fg_color="#196D39", font=("Arial", 14, "bold"), command=guardar_consumo).pack(pady=20)

