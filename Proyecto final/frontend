    ent_pass.pack(pady=10)

    def intentar_login():
        u = ent_user.get()
        p = ent_pass.get()

        usuario = sistema_back.autenticar(u, p)

        if usuario == "usuario_pendiente":
            mostrar_error("Tu cuenta está pendiente de aprobación por el administrador")

        # Solo permitir usuarios normales
        elif usuario and usuario.tipoUsuario != "admin":
            ventana_principal.focus_force()
            ventana_login.destroy()
            abrir_panel_usuario(usuario)

        else:
            mostrar_error("Credenciales de usuario incorrectas")

    ctk.CTkButton(main_frame, text="Entrar", fg_color=Color_boton_oscuro, command=intentar_login).pack(pady=15)

    ctk.CTkButton(main_frame, text="Olvidé mi contraseña", fg_color="transparent", text_color="blue", hover=False, command=lambda: abrir_olvido_pass(ventana_login)).pack()

    def volver_login():
        ventana_menu.deiconify()
        ventana_menu.focus_force()
        ventana_login.destroy()

    ctk.CTkButton(main_frame, text="Volver", fg_color="#8B0000", command=volver_login).pack(pady=10)

